<Window
    x:Class="Cognexalgo.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
    xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
    xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
    skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=FluentLight}"
    Title="COGNEXALGO — Design 1 Preview"
    Height="900" Width="1600"
    WindowStartupLocation="CenterScreen"
    Closing="Window_Closing">

    <Window.Resources>
        <conv:IsNegativeConverter       x:Key="IsNegativeConverter"/>
        <conv:PnlToBrushConverter       x:Key="PnlToBrushConverter"/>
        <conv:StatusBackgroundConverter x:Key="StatusBgConverter"/>
        <conv:StatusForegroundConverter x:Key="StatusFgConverter"/>
        <conv:LogColorConverter         x:Key="LogColorConverter"/>
        <BooleanToVisibilityConverter   x:Key="BoolToVis"/>

        <!-- COLOUR PALETTE -->
        <SolidColorBrush x:Key="BgMain"    Color="#F4F6F9"/>
        <SolidColorBrush x:Key="BgPanel"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderClr" Color="#D0D7E2"/>
        <SolidColorBrush x:Key="NavBg"     Color="#1E3A5F"/>
        <SolidColorBrush x:Key="NavText"   Color="#A8BDD4"/>
        <SolidColorBrush x:Key="NavHover"  Color="#2A4E7A"/>
        <SolidColorBrush x:Key="NavActive" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Accent"    Color="#1E6BC6"/>
        <SolidColorBrush x:Key="Profit"    Color="#16A34A"/>
        <SolidColorBrush x:Key="ProfitBg"  Color="#DCFCE7"/>
        <SolidColorBrush x:Key="Loss"      Color="#DC2626"/>
        <SolidColorBrush x:Key="Warning"   Color="#D97706"/>
        <SolidColorBrush x:Key="TextMain"  Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="TextDim"   Color="#94A3B8"/>

        <!-- NAV BUTTON -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource NavText}"/>
            <Setter Property="Width"      Value="68"/>
            <Setter Property="Height"     Value="56"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="GroupName"  Value="Nav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="8,2">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"   Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource NavActive}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource NavActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- METRIC CARD -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BUTTONS -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.87"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Loss}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="68"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── LEFT NAVY NAV RAIL ────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource NavBg}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Height="60" BorderBrush="#2A4E7A" BorderThickness="0,0,0,1">
                    <!-- Logo placeholder (no image file needed) -->
                    <TextBlock Text="◆" FontSize="28" Foreground="#4A9EFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <RadioButton Style="{StaticResource NavBtn}" IsChecked="True">
                        <StackPanel><TextBlock Text="⊞" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Dash"   FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="◈" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Strats" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="▤" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Pos"    FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="⇄" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Orders" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="Ω" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Chain"  FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="↗" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="P&amp;L" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}">
                        <StackPanel><TextBlock Text="⊙" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="A/c"   FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                    <!-- Settings button — RadioButton avoids style mismatch -->
                    <RadioButton Style="{StaticResource NavBtn}" GroupName="NavSettings">
                        <StackPanel><TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"/><TextBlock Text="Config" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ─── MAIN CONTENT ──────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>

            <!-- STATUS BAR -->
            <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding CurrentPage}"
                               Foreground="{StaticResource TextMain}" FontSize="14" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="{StaticResource ProfitBg}" BorderBrush="#BBF7D0"
                            BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource Profit}" VerticalAlignment="Center" Margin="0,0,5,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.9" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding RunningStrategiesCount, StringFormat={}{0} LIVE}"
                                       Foreground="{StaticResource Profit}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="MTM " Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalMtm, StringFormat=₹{0:N0}}" FontSize="15" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Profit}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalMtm, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Loss}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding MarketTime}" Foreground="{StaticResource TextMuted}"
                               FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource Profit}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="5" Content="⏻ KILL" Style="{StaticResource DangerBtn}"
                            Command="{Binding KillSwitchCommand}" Padding="10,4" FontSize="11"/>
                </Grid>
            </Border>

            <!-- PAGE CONTENT (Dashboard shown by default) -->
            <Border Grid.Row="1">
                <TabControl Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- DASHBOARD -->
                    <TabItem>
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <UniformGrid Grid.Row="0" Columns="5" Margin="0,0,0,14">
                                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="PORTFOLIO MTM" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding TotalMtm, StringFormat=₹{0:N0}}" FontSize="22" Margin="0,4,0,2">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Profit}"/><Style.Triggers><DataTrigger Binding="{Binding TotalMtm, Converter={StaticResource IsNegativeConverter}}" Value="True"><Setter Property="Foreground" Value="{StaticResource Loss}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Today's P&amp;L" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="ACTIVE STRATS" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding RunningStrategiesCount}" Foreground="{StaticResource Accent}" FontSize="22" Margin="0,4,0,2"/>
                                        <TextBlock Text="Running" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="OPEN POSITIONS" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding Positions.Count}" Foreground="{StaticResource TextMain}" FontSize="22" Margin="0,4,0,2"/>
                                        <TextBlock Text="Live legs" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="PENDING ORDERS" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding PendingOrdersCount}" Foreground="{StaticResource Warning}" FontSize="22" Margin="0,4,0,2"/>
                                        <TextBlock Text="Awaiting fill" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="MAX DRAWDOWN" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                        <TextBlock Text="{Binding MaxDrawdown, StringFormat=₹{0:N0}}" Foreground="{StaticResource Loss}" FontSize="22" Margin="0,4,0,2"/>
                                        <TextBlock Text="Today" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="INTRADAY P&amp;L" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,0,10"/>
                                        <syncfusion:SfChart Grid.Row="1" Background="Transparent">
                                            <syncfusion:SfChart.PrimaryAxis>
                                                <syncfusion:DateTimeAxis ShowGridLines="False" AxisLineStyle="{x:Null}" LabelFormat="HH:mm"/>
                                            </syncfusion:SfChart.PrimaryAxis>
                                            <syncfusion:SfChart.SecondaryAxis>
                                                <syncfusion:NumericalAxis ShowGridLines="True" AxisLineStyle="{x:Null}"/>
                                            </syncfusion:SfChart.SecondaryAxis>
                                            <syncfusion:SplineAreaSeries ItemsSource="{Binding PnlHistory}"
                                                XBindingPath="Time" YBindingPath="Value"
                                                Interior="#16A34A15" Stroke="#16A34A" StrokeThickness="2"/>
                                        </syncfusion:SfChart>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="LIVE STRATEGIES" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,0,10"/>
                                        <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding Strategies}"
                                            AutoGenerateColumns="False" HeaderRowHeight="28" RowHeight="36"
                                            Background="Transparent" BorderThickness="0">
                                            <syncfusion:SfDataGrid.Columns>
                                                <syncfusion:GridTextColumn HeaderText="Strategy" MappingName="Name"   />
                                                <syncfusion:GridTextColumn HeaderText="P&amp;L"  MappingName="Pnl"   Width="90" TextAlignment="Right"/>
                                                <syncfusion:GridTextColumn HeaderText="Status"   MappingName="Status" Width="80"/>
                                            </syncfusion:SfDataGrid.Columns>
                                        </syncfusion:SfDataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- STRATEGIES -->
                    <TabItem>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="12,8"
                                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="+ New Strategy" Style="{StaticResource PrimaryBtn}" Command="{Binding AddStrategyCommand}" Margin="0,0,8,0"/>
                                    <Button Content="⟳ Refresh" Style="{StaticResource GhostBtn}" Command="{Binding RefreshStrategiesCommand}"/>
                                </StackPanel>
                            </Border>
                            <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding Strategies}"
                                AutoGenerateColumns="False" AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                                HeaderRowHeight="34" RowHeight="44" GridLinesVisibility="Horizontal" Background="{StaticResource BgMain}">
                                <syncfusion:SfDataGrid.Columns>
                                    <syncfusion:GridTextColumn HeaderText="ID"         MappingName="Id"                 Width="60"/>
                                    <syncfusion:GridTextColumn HeaderText="Strategy"   MappingName="Name"               Width="200"/>
                                    <syncfusion:GridTextColumn HeaderText="Instrument" MappingName="InstrumentType"     Width="110"/>
                                    <syncfusion:GridTextColumn HeaderText="Status"     MappingName="Status"             Width="110"/>
                                    <syncfusion:GridTextColumn HeaderText="Mode"       MappingName="TradingModeDisplay" Width="80"/>
                                    <syncfusion:GridTextColumn HeaderText="P&amp;L"   MappingName="Pnl"                Width="110" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                                    <syncfusion:GridTextColumn HeaderText="LTP"        MappingName="Ltp"                Width="90"  TextAlignment="Right" DisplayBinding="{Binding Ltp, StringFormat=N2}"/>
                                    <syncfusion:GridTextColumn HeaderText="Entry"      MappingName="EntryTime"          Width="90"  DisplayBinding="{Binding EntryTime, StringFormat=HH:mm:ss}"/>
                                    <syncfusion:GridTextColumn HeaderText="Exit"       MappingName="ExitTime"           Width="90"  DisplayBinding="{Binding ExitTime, StringFormat=HH:mm:ss}"/>
                                    <syncfusion:GridTemplateColumn HeaderText="Actions" MappingName="Actions"           Width="160">
                                        <syncfusion:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                    <Button Content="▶" ToolTip="Start"
                                                            Command="{Binding DataContext.StartV2StrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource PrimaryBtn}" Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button Content="■" ToolTip="Stop"
                                                            Command="{Binding DataContext.StopV2StrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button Content="✎" ToolTip="Edit"
                                                            Command="{Binding DataContext.EditStrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,3" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </syncfusion:GridTemplateColumn.CellTemplate>
                                    </syncfusion:GridTemplateColumn>
                                </syncfusion:SfDataGrid.Columns>
                            </syncfusion:SfDataGrid>
                            <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="12,6"
                                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Portfolio P&amp;L: " Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalV2Pnl, StringFormat=₹{0:N0}}" FontSize="16" VerticalAlignment="Center">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Profit}"/><Style.Triggers><DataTrigger Binding="{Binding TotalV2Pnl, Converter={StaticResource IsNegativeConverter}}" Value="True"><Setter Property="Foreground" Value="{StaticResource Loss}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock>
                                    <Button Content="📊 Reports" Style="{StaticResource GhostBtn}" Command="{Binding OpenReportsCommand}" Margin="20,0,0,0" Padding="12,4"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- POSITIONS -->
                    <TabItem>
                        <syncfusion:SfDataGrid ItemsSource="{Binding Positions}" AutoGenerateColumns="False"
                            AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                            HeaderRowHeight="34" RowHeight="40" GridLinesVisibility="Horizontal" Background="{StaticResource BgMain}">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn HeaderText="Symbol"     MappingName="TradingSymbol"  Width="160"/>
                                <syncfusion:GridTextColumn HeaderText="Qty"        MappingName="NetQty"         Width="70"  TextAlignment="Right"/>
                                <syncfusion:GridTextColumn HeaderText="P&amp;L"   MappingName="Pnl"            Width="110" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                                <syncfusion:GridTextColumn HeaderText="Status"     MappingName="Status"         Width="90"/>
                                <syncfusion:GridTextColumn HeaderText="LTP"        MappingName="Ltp"            Width="90"  TextAlignment="Right" DisplayBinding="{Binding Ltp, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="Entry"      MappingName="AvgNetPrice"    Width="90"  TextAlignment="Right" DisplayBinding="{Binding AvgNetPrice, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="SL"         MappingName="StopLoss"       Width="90"  TextAlignment="Right" DisplayBinding="{Binding StopLoss, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="Target"     MappingName="Target"         Width="90"  TextAlignment="Right" DisplayBinding="{Binding Target, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="IV%"        MappingName="IV"             Width="60"  TextAlignment="Right" DisplayBinding="{Binding IV, StringFormat=F1}"/>
                                <syncfusion:GridTextColumn HeaderText="Δ"          MappingName="Delta"          Width="65"  TextAlignment="Right" DisplayBinding="{Binding Delta, StringFormat=F3}"/>
                                <syncfusion:GridTextColumn HeaderText="Θ"          MappingName="Theta"          Width="65"  TextAlignment="Right" DisplayBinding="{Binding Theta, StringFormat=F2}"/>
                                <syncfusion:GridTextColumn HeaderText="Vega"       MappingName="Vega"           Width="65"  TextAlignment="Right" DisplayBinding="{Binding Vega, StringFormat=F2}"/>
                                <syncfusion:GridTemplateColumn HeaderText="Action" MappingName="Action"         Width="80">
                                    <syncfusion:GridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="EXIT" Style="{StaticResource DangerBtn}"
                                                    Command="{Binding DataContext.ExitPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" Padding="10,3" FontSize="10"/>
                                        </DataTemplate>
                                    </syncfusion:GridTemplateColumn.CellTemplate>
                                </syncfusion:GridTemplateColumn>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </TabItem>

                    <!-- ORDERS -->
                    <TabItem>
                        <syncfusion:SfDataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False"
                            AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                            HeaderRowHeight="34" RowHeight="38" GridLinesVisibility="Horizontal" Background="{StaticResource BgMain}">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn HeaderText="Time"     MappingName="Timestamp"       Width="90"  DisplayBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                <syncfusion:GridTextColumn HeaderText="Order ID" MappingName="OrderId"         Width="110"/>
                                <syncfusion:GridTextColumn HeaderText="Type"     MappingName="TransactionType" Width="70"  TextAlignment="Center"/>
                                <syncfusion:GridTextColumn HeaderText="Symbol"   MappingName="Symbol"          Width="160"/>
                                <syncfusion:GridTextColumn HeaderText="Qty"      MappingName="Qty"             Width="70"  TextAlignment="Right"/>
                                <syncfusion:GridTextColumn HeaderText="Price"    MappingName="Price"           Width="90"  TextAlignment="Right" DisplayBinding="{Binding Price, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="Status"   MappingName="Status"          Width="100"/>
                                <syncfusion:GridTextColumn HeaderText="Strategy" MappingName="StrategyName"   />
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </TabItem>

                    <!-- OPTION CHAIN -->
                    <TabItem>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="12,8"
                                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Index:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Width="130" SelectedItem="{Binding SelectedOptionIndex}" Margin="0,0,12,0">
                                        <ComboBoxItem>NIFTY</ComboBoxItem><ComboBoxItem>BANKNIFTY</ComboBoxItem><ComboBoxItem>FINNIFTY</ComboBoxItem>
                                    </ComboBox>
                                    <Button Content="⟳ Load Chain" Style="{StaticResource PrimaryBtn}" Command="{Binding FetchOptionChainCommand}" Margin="0,0,20,0"/>
                                    <TextBlock Text="Spot: " Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SpotPrice, StringFormat=₹{0:N2}}" Foreground="{StaticResource Accent}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding OptionChain}" AutoGenerateColumns="False"
                                AllowSorting="True" HeaderRowHeight="34" RowHeight="36" GridLinesVisibility="Horizontal" Background="{StaticResource BgMain}">
                                <syncfusion:SfDataGrid.Columns>
                                    <syncfusion:GridTextColumn HeaderText="Strike"  MappingName="Strike"       Width="90"  TextAlignment="Right"/>
                                    <syncfusion:GridTextColumn HeaderText="Type"    MappingName="OptionType"   Width="60"  TextAlignment="Center"/>
                                    <syncfusion:GridTextColumn HeaderText="LTP"     MappingName="LTP"          Width="90"  TextAlignment="Right" DisplayBinding="{Binding LTP, StringFormat=N2}"/>
                                    <syncfusion:GridTextColumn HeaderText="IV%"     MappingName="IV"           Width="80"  TextAlignment="Right" DisplayBinding="{Binding IV, StringFormat=F2}"/>
                                    <syncfusion:GridTextColumn HeaderText="Delta"   MappingName="Delta"        Width="80"  TextAlignment="Right" DisplayBinding="{Binding Delta, StringFormat=F3}"/>
                                    <syncfusion:GridTextColumn HeaderText="Gamma"   MappingName="Gamma"        Width="80"  TextAlignment="Right" DisplayBinding="{Binding Gamma, StringFormat=F4}"/>
                                    <syncfusion:GridTextColumn HeaderText="Theta"   MappingName="Theta"        Width="80"  TextAlignment="Right" DisplayBinding="{Binding Theta, StringFormat=F2}"/>
                                    <syncfusion:GridTextColumn HeaderText="Vega"    MappingName="Vega"         Width="80"  TextAlignment="Right" DisplayBinding="{Binding Vega, StringFormat=F2}"/>
                                    <syncfusion:GridTextColumn HeaderText="DTE"     MappingName="DaysToExpiry" Width="60"  TextAlignment="Center"/>
                                    <syncfusion:GridTextColumn HeaderText="Symbol"  MappingName="Symbol"      />
                                </syncfusion:SfDataGrid.Columns>
                            </syncfusion:SfDataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ANALYTICS (placeholder) -->
                    <TabItem>
                        <Border Background="{StaticResource BgMain}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="↗" FontSize="48" Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Analytics Dashboard" FontSize="22"
                                           Foreground="{StaticResource TextMain}" HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                <TextBlock Text="Enterprise analytics will appear here in the live application."
                                           Foreground="{StaticResource TextMuted}" FontSize="13" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <!-- ACCOUNTS -->
                    <TabItem>
                        <syncfusion:SfDataGrid ItemsSource="{Binding AccountManager.Accounts}" AutoGenerateColumns="False"
                            AllowResizingColumns="True" AllowSorting="True"
                            HeaderRowHeight="34" RowHeight="38" GridLinesVisibility="Horizontal" Background="{StaticResource BgMain}">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn HeaderText="A/C Name"    MappingName="AccountName"    Width="150"/>
                                <syncfusion:GridTextColumn HeaderText="Broker"       MappingName="Broker"         Width="100"/>
                                <syncfusion:GridTextColumn HeaderText="Client ID"    MappingName="ClientId"       Width="100"/>
                                <syncfusion:GridTextColumn HeaderText="Status"       MappingName="Status"         Width="100"/>
                                <syncfusion:GridTextColumn HeaderText="P&amp;L"     MappingName="Pnl"            Width="110" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                                <syncfusion:GridTextColumn HeaderText="Funds Avail"  MappingName="FundsAvailable" Width="110" TextAlignment="Right"/>
                                <syncfusion:GridTextColumn HeaderText="Pos Open"     MappingName="PositionOpen"   Width="90"  TextAlignment="Right"/>
                                <syncfusion:GridTextColumn HeaderText="Orders"       MappingName="OrderTotal"     Width="90"  TextAlignment="Right"/>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </TabItem>

                </TabControl>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderClr}" Cursor="SizeNS"/>

            <!-- LOG PANEL -->
            <Border Grid.Row="3" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgMain}"
                            BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="10,0">
                            <TextBlock Text="SYSTEM LOG" Foreground="{StaticResource TextMuted}"
                                       FontSize="10" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Button Content="CLEAR" Style="{StaticResource GhostBtn}"
                                    Command="{Binding ClearLogCommand}" Margin="12,0,0,0" Padding="8,2" FontSize="10"/>
                        </StackPanel>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}"
                             Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"
                             VirtualizingPanel.IsVirtualizing="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{Binding Converter={StaticResource LogColorConverter}}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
