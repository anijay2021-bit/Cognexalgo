<UserControl x:Class="Cognexalgo.UI.Views.VCP.VCPScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Cognexalgo.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VCPScannerViewModel, IsDesignTimeCreatable=False}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <!-- ProgressBar with rounded corners for trade progress column -->
        <Style x:Key="VCPProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height"   Value="8"/>
            <Setter Property="Minimum"  Value="0"/>
            <Setter Property="Maximum"  Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#333333" CornerRadius="4">
                            <Grid x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="#64B5F6"
                                        CornerRadius="4"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════
             TOP STATS BAR
        ════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Height="64"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Card 1: Engine Status -->
                <StackPanel Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding EngineStatus}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{Binding EngineStatusColor,
                                   Converter={StaticResource StringToBrushConverter}}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="ENGINE"
                               FontSize="10" Foreground="#888888"
                               Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="4,8"/>

                <!-- Card 2: Total P&L -->
                <StackPanel Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalPnLFormatted}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{Binding TotalPnLColor,
                                   Converter={StaticResource StringToBrushConverter}}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="TOTAL P&amp;L"
                               FontSize="10" Foreground="#888888"
                               Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="4,8"/>

                <!-- Card 3: Win Rate -->
                <StackPanel Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding WinRateDisplay}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#64B5F6"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="WIN RATE"
                               FontSize="10" Foreground="#888888"
                               Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="4,8"/>

                <!-- Card 4: Active Signals -->
                <StackPanel Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ActiveSignalCount}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#FFD700"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="SIGNALS"
                               FontSize="10" Foreground="#888888"
                               Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="4,8"/>

                <!-- Card 5: Open Trades -->
                <StackPanel Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding OpenTradeCount}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#00BCD4"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="OPEN TRADES"
                               FontSize="10" Foreground="#888888"
                               Margin="0,2,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             TAB CONTROL
        ════════════════════════════════════════════════════════ -->
        <TabControl>

            <!-- ── Tab 1: Active Signals ───────────────────── -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="📡 Active Signals ("/>
                        <Run Text="{Binding ActiveSignalCount, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>

                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          RowStyle="{StaticResource DarkDataGridRowStyle}"
                          ItemsSource="{Binding ActiveSignals}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Symbol"    Width="90"
                                            Binding="{Binding Symbol}"/>

                        <!-- Quality column with colour badge -->
                        <DataGridTemplateColumn Header="Quality" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding QualityColor,
                                                Converter={StaticResource StringToBrushConverter}}"
                                            CornerRadius="3" Padding="4,1"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Quality}"
                                                   FontWeight="Bold"
                                                   Foreground="Black"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Timeframe" Width="65"
                                            Binding="{Binding Timeframe}"/>

                        <DataGridTextColumn Header="Pivot"     Width="80"
                                            Binding="{Binding PivotLevel, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Stop Loss" Width="80"
                                            Binding="{Binding StopLoss, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Target 1"  Width="80"
                                            Binding="{Binding Target1, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Target 2"  Width="80"
                                            Binding="{Binding Target2, StringFormat=N0}"/>

                        <DataGridTextColumn Header="R:R"       Width="55"
                                            Binding="{Binding RiskReward, StringFormat=F1}"/>

                        <DataGridTextColumn Header="Strike"    Width="100"
                                            Binding="{Binding Strike}"/>

                        <DataGridTextColumn Header="Expiry"    Width="90"
                                            Binding="{Binding Expiry}"/>

                        <DataGridTextColumn Header="Age"       Width="70"
                                            Binding="{Binding SignalAge}"/>

                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Tab 2: Open Trades ──────────────────────── -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="📊 Open Trades ("/>
                        <Run Text="{Binding OpenTradeCount, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>

                <DataGrid Style="{StaticResource DarkDataGridStyle}"
                          RowStyle="{StaticResource DarkDataGridRowStyle}"
                          ItemsSource="{Binding OpenTrades}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Symbol"    Width="90"
                                            Binding="{Binding Symbol}"/>

                        <DataGridTextColumn Header="Strike"    Width="100"
                                            Binding="{Binding Strike}"/>

                        <DataGridTextColumn Header="Timeframe" Width="65"
                                            Binding="{Binding Timeframe}"/>

                        <DataGridTextColumn Header="Entry"     Width="80"
                                            Binding="{Binding EntryPrice, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Current"   Width="80"
                                            Binding="{Binding CurrentPrice, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Stop Loss" Width="80"
                                            Binding="{Binding StopLoss, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Target 1"  Width="80"
                                            Binding="{Binding Target1, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Target 2"  Width="80"
                                            Binding="{Binding Target2, StringFormat=N0}"/>

                        <DataGridTextColumn Header="Lots"      Width="55"
                                            Binding="{Binding LotsOpen}"/>

                        <!-- P&L with colour -->
                        <DataGridTemplateColumn Header="P&amp;L" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding UnrealizedPnL, StringFormat='₹{0:N0}'}"
                                               FontWeight="Bold"
                                               Foreground="{Binding PnLColor,
                                                   Converter={StaticResource StringToBrushConverter}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Padding="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Progress bar -->
                        <DataGridTemplateColumn Header="Progress" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ProgressBar Value="{Binding ProgressValue}"
                                                 Minimum="0" Maximum="100"
                                                 Style="{StaticResource VCPProgressBarStyle}"
                                                 VerticalAlignment="Center"
                                                 Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Status"    Width="80"
                                            Binding="{Binding Status}"/>

                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Tab 3: Trade History ────────────────────── -->
            <TabItem Header="📋 Trade History">
                <DockPanel>

                    <!-- Summary row at bottom -->
                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal">

                            <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,24,0"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="Total Trades: "/>
                                <Run Text="{Binding TotalTrades, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,24,0"
                                       Foreground="#00C853">
                                <Run Text="Winners: "/>
                                <Run Text="{Binding WinCount, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,24,0"
                                       Foreground="#FF1744">
                                <Run Text="Losers: "/>
                                <Run Text="{Binding LossCount, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,24,0"
                                       Foreground="#64B5F6">
                                <Run Text="Win Rate: "/>
                                <Run Text="{Binding WinRateDisplay, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TotalPnLColor,
                                           Converter={StaticResource StringToBrushConverter}}">
                                <Run Text="Total P&amp;L: "/>
                                <Run Text="{Binding TotalPnLFormatted, Mode=OneWay}"/>
                            </TextBlock>

                        </StackPanel>
                    </Border>

                    <!-- History DataGrid -->
                    <DataGrid Style="{StaticResource DarkDataGridStyle}"
                              RowStyle="{StaticResource DarkDataGridRowStyle}"
                              ItemsSource="{Binding TradeHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Symbol"     Width="90"
                                                Binding="{Binding Symbol}"/>

                            <DataGridTextColumn Header="Strike"     Width="100"
                                                Binding="{Binding Strike}"/>

                            <DataGridTextColumn Header="Timeframe"  Width="65"
                                                Binding="{Binding Timeframe}"/>

                            <DataGridTextColumn Header="Entry"      Width="80"
                                                Binding="{Binding EntryPrice, StringFormat=N0}"/>

                            <DataGridTextColumn Header="Exit"       Width="80"
                                                Binding="{Binding ExitPrice, StringFormat=N0}"/>

                            <DataGridTextColumn Header="Lots"       Width="55"
                                                Binding="{Binding LotsOpen}"/>

                            <!-- P&L with colour -->
                            <DataGridTemplateColumn Header="P&amp;L" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UnrealizedPnL, StringFormat='₹{0:N0}'}"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding PnLColor,
                                                       Converter={StaticResource StringToBrushConverter}}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Exit Reason" Width="110"
                                                Binding="{Binding ExitTriggerDisplay}"/>

                            <DataGridTextColumn Header="Entry Time"  Width="130"
                                                Binding="{Binding EntryTime, StringFormat='dd-MMM HH:mm'}"/>

                            <DataGridTextColumn Header="Exit Time"   Width="130"
                                                Binding="{Binding ExitTime, StringFormat='dd-MMM HH:mm'}"/>

                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>
            </TabItem>

        </TabControl>

    </DockPanel>
</UserControl>
