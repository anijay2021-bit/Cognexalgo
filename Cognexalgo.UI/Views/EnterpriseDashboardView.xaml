<UserControl x:Class="Cognexalgo.UI.Views.EnterpriseDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cognexalgo.UI.Views"
             xmlns:vm="clr-namespace:Cognexalgo.UI.ViewModels"
             xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:PnlToBrushConverter x:Key="PnlToBrushConverter"/>
        <conv:KillSwitchStatusToBrushConverter x:Key="KillSwitchStatusToBrushConverter"/>
    </UserControl.Resources>
    
    <Grid Background="Transparent">
        <!-- UNIFIED LEGS GRID -->
        <Border Margin="15" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{StaticResource CardBrush}" Padding="15,10" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                    <TextBlock Text="ACTIVE TRADE POSITIONS" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI Variable, Inter, Segoe UI, sans-serif"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveLegs}"
                          Style="{StaticResource DarkDataGridStyle}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowStyle="{StaticResource DarkDataGridRowStyle}"
                          Background="{StaticResource CardBrush}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SYMBOL" Binding="{Binding Symbol}" Width="*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="ENTRY" Binding="{Binding EntryPrice, StringFormat='N2'}" Width="120"/>
                        <DataGridTextColumn Header="LTP" Binding="{Binding Ltp, StringFormat='N2'}" Width="120" CellStyle="{StaticResource FlashCellStyle}"/>
                        <DataGridTextColumn Header="PNL" Binding="{Binding Pnl, StringFormat='N2'}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Pnl, Converter={StaticResource PnlToBrushConverter}}" Value="Negative">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Pnl, Converter={StaticResource PnlToBrushConverter}}" Value="Positive">
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
