<Window x:Class="Cognexalgo.UI.Views.CalendarTradesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        Title="{Binding Title}"
        Width="1020" Height="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Local colour tokens (mirrors MainWindow) -->
        <SolidColorBrush x:Key="Positive"  Color="#2E7D32"/>
        <SolidColorBrush x:Key="Negative"  Color="#C62828"/>
        <SolidColorBrush x:Key="SurfaceSep" Color="#E0E0E0"/>

        <!-- Cell alignment helpers -->
        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
        <Style x:Key="CellRight" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Padding"             Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{Binding Title}"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMainBrush}"
                   Margin="0,0,0,12"/>

        <!-- Trade History DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Legs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Style="{StaticResource DarkDataGridStyle}"
                  RowHeight="38"
                  HeadersVisibility="Column">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Symbol"     Binding="{Binding Symbol}"     Width="*"  MinWidth="180"/>
                <DataGridTextColumn Header="Type"       Binding="{Binding Type}"        Width="60" ElementStyle="{StaticResource CellCenter}"/>
                <DataGridTextColumn Header="Expiry"     Binding="{Binding ExpiryType}"  Width="80" ElementStyle="{StaticResource CellCenter}"/>
                <DataGridTextColumn Header="Action"     Binding="{Binding Action}"      Width="70" ElementStyle="{StaticResource CellCenter}"/>

                <DataGridTextColumn Header="Entry ₹"   Binding="{Binding EntryPrice,   StringFormat=N2}" Width="90" ElementStyle="{StaticResource CellRight}"/>
                <DataGridTextColumn Header="Current ₹" Binding="{Binding CurrentPrice, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CellRight}"/>

                <!-- P&L column — green/red -->
                <DataGridTemplateColumn Header="P&amp;L ₹" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Pnl, StringFormat=N0}"
                                       TextAlignment="Right" Padding="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Pnl, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#2E7D32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="EXITED">
                                                <Setter Property="Background" Value="#616161"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Entry Time" Binding="{Binding EntryTime, StringFormat=HH:mm:ss}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                <DataGridTextColumn Header="Exit Time"  Binding="{Binding ExitTime,  StringFormat=HH:mm:ss}" Width="90" ElementStyle="{StaticResource CellCenter}"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- P&L Footer -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceSep}"
                Opacity="0.4"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">

                <TextBlock Text="Realized: " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Realized, StringFormat=₹{0:N0}}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Realized, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="Unrealized: " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Unrealized, StringFormat=₹{0:N0}}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Realized, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="Net P&amp;L: " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Total, StringFormat=₹{0:N0}}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Total, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>
    </Grid>
</Window>
