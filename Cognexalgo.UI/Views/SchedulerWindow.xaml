<Window x:Class="Cognexalgo.UI.Views.SchedulerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Strategy Scheduler"
        Width="940" Height="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Form row 1: core -->
            <RowDefinition Height="Auto"/>  <!-- Form row 2: CP fields (conditional) -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="STRATEGY SCHEDULER"
                   Style="{StaticResource HeaderTextStyle}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- ── Core form ── -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="15,12"
                Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>   <!-- Strategy -->
                    <ColumnDefinition Width="*"/>      <!-- Symbol -->
                    <ColumnDefinition Width="72"/>     <!-- Entry -->
                    <ColumnDefinition Width="72"/>     <!-- Exit -->
                    <ColumnDefinition Width="58"/>     <!-- SL % -->
                    <ColumnDefinition Width="66"/>     <!-- Tgt % -->
                    <ColumnDefinition Width="46"/>     <!-- Lots -->
                    <ColumnDefinition Width="*"/>      <!-- Strike mode -->
                    <ColumnDefinition Width="60"/>     <!-- Live -->
                    <ColumnDefinition Width="70"/>     <!-- Add -->
                    <ColumnDefinition Width="70"/>     <!-- Remove -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Labels row -->
                <TextBlock Grid.Row="0" Grid.Column="0"  Text="Strategy"    Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1"  Text="Symbol"      Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="2"  Text="Entry"       Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="3"  Text="Exit"        Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="4"  Text="SL %"        Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="5"  Text="Target %"    Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="6"  Text="Lots"        Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="7"  Text="Strike Mode" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="8"  Text="Live"        Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,2"/>

                <!-- Controls row -->
                <ComboBox Grid.Row="1" Grid.Column="0"
                          ItemsSource="{Binding StrategyNames}"
                          SelectedItem="{Binding StrategyName}"
                          Margin="0,0,8,0"/>

                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding Symbols}"
                          SelectedItem="{Binding Symbol}"
                          Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="2"
                         Text="{Binding EntryTimeText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="3"
                         Text="{Binding ExitTimeText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="4"
                         Text="{Binding SlPercent}"
                         Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="5"
                         Text="{Binding TargetPercent}"
                         Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="6"
                         Text="{Binding TotalLots}"
                         Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,8,0"/>

                <ComboBox Grid.Row="1" Grid.Column="7"
                          ItemsSource="{Binding StrikeModes}"
                          SelectedItem="{Binding StrikeMode}"
                          Margin="0,0,8,0"/>

                <CheckBox Grid.Row="1" Grid.Column="8"
                          IsChecked="{Binding IsLiveMode}"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextMainBrush}"
                          Margin="4,0,8,0"/>

                <Button Grid.Row="1" Grid.Column="9"
                        Content="Add"
                        Command="{Binding AddScheduleCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,6,0"/>

                <Button Grid.Row="1" Grid.Column="10"
                        Content="Remove"
                        Command="{Binding RemoveScheduleCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </Grid>
        </Border>

        <!-- ── Closest Premium sub-form (visible only when StrikeMode = ClosestPremium) ── -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="15,10"
                Margin="0,0,0,8"
                Visibility="{Binding IsClosestPremiumMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Dynamic Strike Selection — Closest Premium"
                           Foreground="#00BCD4" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Operator" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding PremiumOperators}"
                              SelectedItem="{Binding PremiumOperator}"
                              Width="70"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Target Premium (₹)" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBox Text="{Binding TargetPremium}"
                             Style="{StaticResource DarkTextBoxStyle}"
                             Width="100"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Tolerance (₹)" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBox Text="{Binding PremiumTolerance}"
                             Style="{StaticResource DarkTextBoxStyle}"
                             Width="80"/>
                </StackPanel>

                <TextBlock VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}">
                    <TextBlock.Text>
                        Tolerance = 0 → always enter closest (no guard)
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Schedules DataGrid ── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Schedules}"
                  SelectedItem="{Binding SelectedSchedule}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Style="{StaticResource DarkDataGridStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Strategy"    Binding="{Binding StrategyName}"     Width="150"/>
                <DataGridTextColumn Header="Symbol"      Binding="{Binding Symbol}"            Width="75"/>
                <DataGridTextColumn Header="Entry"       Binding="{Binding EntryTime, StringFormat=\{0:HH\\:mm\}}" Width="60"/>
                <DataGridTextColumn Header="Exit"        Binding="{Binding ExitTime,  StringFormat=\{0:HH\\:mm\}}" Width="60"/>
                <DataGridTextColumn Header="SL %"        Binding="{Binding SlPercent,     StringFormat=N1}" Width="50"/>
                <DataGridTextColumn Header="Target %"    Binding="{Binding TargetPercent, StringFormat=N1}" Width="60"/>
                <DataGridTextColumn Header="Lots"        Binding="{Binding TotalLots}"         Width="40"/>
                <DataGridTextColumn Header="Strike"      Binding="{Binding StrikeMode}"        Width="110"/>
                <DataGridTextColumn Header="Prem ₹"     Binding="{Binding TargetPremium,  StringFormat=N0}" Width="60"/>
                <DataGridTextColumn Header="Op"          Binding="{Binding PremiumOperator}"   Width="35"/>
                <DataGridTextColumn Header="Tol"         Binding="{Binding PremiumTolerance,  StringFormat=N0}" Width="40"/>
                <DataGridCheckBoxColumn Header="Live"    Binding="{Binding IsLiveMode}"        Width="40"/>
                <DataGridCheckBoxColumn Header="On"      Binding="{Binding IsActive}"          Width="35"/>
                <DataGridTextColumn Header="Fired"       Binding="{Binding LastFiredDate}"     Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="11"
                   Margin="0,8,0,0"/>
    </Grid>
</Window>
