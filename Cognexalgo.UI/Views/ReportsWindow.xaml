<Window x:Class="Cognexalgo.UI.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Cognexalgo.UI.ViewModels"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        xmlns:chart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
        mc:Ignorable="d"
        Title="Performance Report"
        Width="960" Height="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <SolidColorBrush x:Key="Positive" Color="#2E7D32"/>
        <SolidColorBrush x:Key="Negative" Color="#C62828"/>

        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
        <Style x:Key="CellRight" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Padding"             Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Filter bar -->
            <RowDefinition Height="Auto"/>   <!-- Stats cards -->
            <RowDefinition Height="180"/>    <!-- Equity curve chart -->
            <RowDefinition Height="*"/>      <!-- Per-strategy breakdown -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="PERFORMANCE REPORT"
                   Style="{StaticResource HeaderTextStyle}"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <!-- Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Period:" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{x:Static vm:ReportsViewModel.DateRanges}"
                          SelectedItem="{Binding SelectedRange}"
                          Style="{StaticResource DarkComboBoxStyle}"
                          Width="130" Margin="0,0,16,0"/>
                <Button Content="Load Report"
                        Command="{Binding LoadReportCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"/>
                <TextBlock Text="Loading..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                           Style="{StaticResource LabelTextStyle}" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Stats cards -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
            <UniformGrid Columns="7" HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Total Trades" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalTrades}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Win %" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding WinPct, StringFormat='{}{0:F1}%'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Total P&amp;L" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPnl, StringFormat='₹{0:N0}'}" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TotalPnl, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Avg P&amp;L" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding AvgTradePnl, StringFormat='₹{0:N0}'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Max DD" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MaxDrawdown, StringFormat='₹{0:N0}'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Sharpe" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding SharpeRatio, StringFormat='{}{0:F2}'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="4,0">
                    <TextBlock Text="W / L" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="WinningTrades"/>
                                <Binding Path="LosingTrades"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

            </UniformGrid>
        </Border>

        <!-- Equity Curve Chart -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="8,4" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Equity Curve"
                           Style="{StaticResource LabelTextStyle}" Margin="4,2,0,4"/>
                <chart:SfChart Grid.Row="1"
                               Background="Transparent"
                               BorderThickness="0"
                               Margin="0,0,8,0">
                    <chart:SfChart.PrimaryAxis>
                        <chart:CategoryAxis ShowGridLines="False" Visibility="Collapsed"/>
                    </chart:SfChart.PrimaryAxis>
                    <chart:SfChart.SecondaryAxis>
                        <chart:NumericalAxis LabelFormat="₹#,0"
                                             ShowGridLines="True"/>
                    </chart:SfChart.SecondaryAxis>
                    <chart:LineSeries ItemsSource="{Binding EquityCurve}"
                                      XBindingPath="Label"
                                      YBindingPath="CumPnl"
                                      Stroke="{StaticResource PrimaryBrush}"
                                      StrokeThickness="2"
                                      EnableAnimation="False"/>
                </chart:SfChart>

                <!-- Empty state label -->
                <TextBlock Grid.Row="1"
                           Text="No data — select a period and click Load Report"
                           Style="{StaticResource LabelTextStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Per-strategy breakdown -->
        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Per-Strategy Breakdown"
                           Style="{StaticResource LabelTextStyle}" Margin="4,0,0,6"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding StrategyRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Style="{StaticResource DarkDataGridStyle}"
                          CanUserSortColumns="True"
                          RowHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Strategy"      Binding="{Binding StrategyId}"                                       Width="*"/>
                        <DataGridTextColumn Header="Trades"        Binding="{Binding Trades}"                                           Width="80"  ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Win %"         Binding="{Binding WinPct, StringFormat='{}{0:F1}%'}"                  Width="80"  ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Total P&amp;L" Binding="{Binding TotalPnl, StringFormat='₹{0:N0}'}"                  Width="120" ElementStyle="{StaticResource CellRight}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Window>
