<Window x:Class="Cognexalgo.UI.Views.CalendarPerformanceDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        Title="Calendar Strategy — Performance Dashboard"
        Width="1100" Height="740"
        Background="#06101A"
        FontFamily="Segoe UI Variable Text"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:IsNegativeConverter x:Key="IsNeg"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Metric card ── -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="#111E30"/>
            <Setter Property="BorderBrush"     Value="#1C304A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
        </Style>

        <!-- ── Flat button base ── -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ── DataGrid — column header ── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#0B1520"/>
            <Setter Property="Foreground"       Value="#4A6FA5"/>
            <Setter Property="FontFamily"       Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize"         Value="10"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="Height"           Value="28"/>
            <Setter Property="BorderBrush"      Value="#1C304A"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
            <Setter Property="SeparatorBrush"   Value="#1C304A"/>
        </Style>

        <!-- ── DataGrid — cell ── -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#A0B8D0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#162848"/>
                    <Setter Property="Foreground" Value="#D4E5F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid — row ── -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background"    Value="#0A1628"/>
            <Setter Property="BorderBrush"   Value="#1C304A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground"    Value="#A0B8D0"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#091220"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#162848"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#132038"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Cell alignment helpers ── -->
        <Style x:Key="CellRight" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Padding"             Value="0,0,8,0"/>
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="FontSize"            Value="12"/>
        </Style>
        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="FontSize"            Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>    <!-- Header bar -->
            <RowDefinition Height="Auto"/>  <!-- Metric cards -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Trade log -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════
             Row 0 — Header bar
             ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0B1520"
                BorderBrush="#1C304A" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <!-- Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PERFORMANCE DASHBOARD"
                               FontFamily="Bahnschrift" FontSize="15" FontWeight="SemiBold"
                               Foreground="#D4E5F7" VerticalAlignment="Center"
                              />
                    <Rectangle Width="1" Fill="#1C304A" Margin="14,8"/>
                    <TextBlock Text="{Binding StrategyName}"
                               FontFamily="Bahnschrift" FontSize="13"
                               Foreground="#00D4E8" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════
             Row 1 — 6 Metric Cards
             ════════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="6" Margin="20,14,20,0">

            <!-- Total Trades -->
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="TOTAL TRADES"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock Text="{Binding TotalTrades}"
                               FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                               Foreground="#D4E5F7" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Win Rate -->
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="WIN RATE"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock Text="{Binding WinRate}"
                               FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                               Foreground="#00D084" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Max Drawdown -->
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="MAX DRAWDOWN"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock Text="{Binding MaxDrawdown}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="#FF5252" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Avg Roll P&L -->
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="AVG ROLL P&amp;L"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Margin="0,6,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="{Binding AvgWeeklyRollPnL}"/>
                                <Setter Property="Foreground" Value="#00D084"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvgWeeklyRollPnL, Converter={StaticResource IsNeg}}" Value="True">
                                        <Setter Property="Foreground" Value="#FF5252"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Hedge Cost -->
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="HEDGE COST"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock Text="{Binding TotalHedgeCost}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="#FFB800" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Net Hedge Benefit -->
            <Border Style="{StaticResource MetricCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="NET HEDGE BENEFIT"
                               FontFamily="Bahnschrift" FontSize="9" FontWeight="SemiBold"
                               Foreground="#4A6FA5"/>
                    <TextBlock Text="{Binding NetHedgeBenefit}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="#4FC3F7" Margin="0,6,0,0"/>
                    <TextBlock Text="est. 3× margin relief"
                               FontFamily="Segoe UI Variable Text" FontSize="9"
                               Foreground="#2A4A6A" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ════════════════════════════════════════════════
             Row 2 — Toolbar
             ════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,12,20,8">
            <Button Command="{Binding RefreshCommand}"
                    Width="110" Height="28" Margin="0,0,8,0"
                    Background="#0D2137" BorderBrush="#00D4E8"
                    Template="{StaticResource FlatBtn}" Padding="0">
                <TextBlock Text="↻  REFRESH"
                           FontFamily="Bahnschrift" FontSize="11" FontWeight="SemiBold"
                           Foreground="#00D4E8"/>
            </Button>
            <Button Command="{Binding ExportToCsvCommand}"
                    Width="120" Height="28"
                    Background="#0D2137" BorderBrush="#4A6FA5"
                    Template="{StaticResource FlatBtn}" Padding="0">
                <TextBlock Text="↓  EXPORT CSV"
                           FontFamily="Bahnschrift" FontSize="11" FontWeight="SemiBold"
                           Foreground="#A0B8D0"/>
            </Button>
        </StackPanel>

        <!-- ════════════════════════════════════════════════
             Row 3 — Trade Log DataGrid
             ════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Margin="20,0,20,16"
                Background="#0A1628"
                BorderBrush="#1C304A" BorderThickness="1" CornerRadius="6">
            <DataGrid ItemsSource="{Binding TradeLog}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      AlternationCount="2"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#0F1E32"
                      VerticalGridLinesBrush="Transparent"
                      Background="Transparent"
                      RowBackground="Transparent"
                      BorderThickness="0"
                      RowHeight="32"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Date"
                        Binding="{Binding Date, StringFormat={}{0:dd-MMM-yy}}"
                        Width="82" ElementStyle="{StaticResource CellCenter}"/>

                    <DataGridTextColumn Header="Time"
                        Binding="{Binding Date, StringFormat={}{0:HH:mm:ss}}"
                        Width="72" ElementStyle="{StaticResource CellCenter}"/>

                    <!-- Event type badge -->
                    <DataGridTemplateColumn Header="Event" Width="106">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="7,2"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0A1E3A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EventType}" Value="ROLL">
                                                    <Setter Property="Background" Value="#002B1A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="SL_HIT">
                                                    <Setter Property="Background" Value="#2A0A0A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="FLIP_BUY">
                                                    <Setter Property="Background" Value="#2A1800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="FLIP_SELL">
                                                    <Setter Property="Background" Value="#1E1400"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="HEDGE_BUY">
                                                    <Setter Property="Background" Value="#001630"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="HEDGE_EXIT">
                                                    <Setter Property="Background" Value="#1A0830"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventType}" Value="EXIT">
                                                    <Setter Property="Background" Value="#14202E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding EventType}"
                                               FontFamily="Bahnschrift" FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A6FA5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EventType}" Value="ROLL">
                                                        <Setter Property="Foreground" Value="#00D084"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="SL_HIT">
                                                        <Setter Property="Foreground" Value="#FF5252"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="FLIP_BUY">
                                                        <Setter Property="Foreground" Value="#FFB800"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="FLIP_SELL">
                                                        <Setter Property="Foreground" Value="#FF9F00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="HEDGE_BUY">
                                                        <Setter Property="Foreground" Value="#4FC3F7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="HEDGE_EXIT">
                                                        <Setter Property="Foreground" Value="#CE93D8"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EventType}" Value="EXIT">
                                                        <Setter Property="Foreground" Value="#7B8FA6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Description"
                        Binding="{Binding LegDescription}"
                        Width="*" MinWidth="200"/>

                    <DataGridTextColumn Header="Entry ₹"
                        Binding="{Binding EntryPrice, StringFormat=N2}"
                        Width="84" ElementStyle="{StaticResource CellRight}"/>

                    <DataGridTextColumn Header="Exit ₹"
                        Binding="{Binding ExitPrice, StringFormat=N2}"
                        Width="84" ElementStyle="{StaticResource CellRight}"/>

                    <!-- P&L -->
                    <DataGridTemplateColumn Header="P&amp;L ₹" Width="92">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PnL, StringFormat=N2}"
                                           TextAlignment="Right" Padding="0,0,8,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#00D084"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PnL, Converter={StaticResource IsNeg}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Cumulative P&L -->
                    <DataGridTemplateColumn Header="Cum P&amp;L ₹" Width="104">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CumulativePnL, StringFormat=N2}"
                                           TextAlignment="Right" Padding="0,0,8,0"
                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                           FontFamily="Consolas" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#00D4E8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CumulativePnL, Converter={StaticResource IsNeg}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Hedged"
                        Binding="{Binding WasHedged}"
                        Width="62" ElementStyle="{StaticResource CellCenter}"/>

                    <DataGridTextColumn Header="Hedge ₹"
                        Binding="{Binding HedgeCost, StringFormat=N2}"
                        Width="84" ElementStyle="{StaticResource CellRight}"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Window>
