<Window x:Class="Cognexalgo.UI.Views.CalendarPerformanceDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        Title="Calendar Strategy — Performance Dashboard"
        Width="1080" Height="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Metric card style -->
        <Style x:Key="MetricCardBorder" TargetType="Border">
            <Setter Property="Background"     Value="#161B2E"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="14,12"/>
            <Setter Property="Margin"         Value="0,0,10,0"/>
        </Style>

        <Style x:Key="CellRight" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Padding"             Value="0,0,6,0"/>
        </Style>
        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Metric cards -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Trade log grid -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="PERFORMANCE DASHBOARD"
                       Style="{StaticResource HeaderTextStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock Text=" — "
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center" FontSize="14"/>
            <TextBlock Text="{Binding StrategyName}"
                       Foreground="#00BCD4" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── 6 Metric Cards ── -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="6" Margin="0,0,0,14">

            <!-- Total Trades -->
            <Border Style="{StaticResource MetricCardBorder}">
                <StackPanel>
                    <TextBlock Text="Total Trades"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding TotalTrades}"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Win Rate -->
            <Border Style="{StaticResource MetricCardBorder}">
                <StackPanel>
                    <TextBlock Text="Win Rate"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding WinRate}"
                               Foreground="#4CAF50"
                               FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Max Drawdown -->
            <Border Style="{StaticResource MetricCardBorder}">
                <StackPanel>
                    <TextBlock Text="Max Drawdown"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding MaxDrawdown}"
                               Foreground="#F44336"
                               FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Avg Weekly Roll P&L -->
            <Border Style="{StaticResource MetricCardBorder}">
                <StackPanel>
                    <TextBlock Text="Avg Roll P&amp;L"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock FontSize="18" FontWeight="Bold" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="{Binding AvgWeeklyRollPnL}"/>
                                <Setter Property="Foreground" Value="#4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvgWeeklyRollPnL, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Hedge Cost -->
            <Border Style="{StaticResource MetricCardBorder}">
                <StackPanel>
                    <TextBlock Text="Hedge Cost"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding TotalHedgeCost}"
                               Foreground="#FF9800"
                               FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Net Hedge Benefit -->
            <Border Style="{StaticResource MetricCardBorder}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Net Hedge Benefit"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding NetHedgeBenefit}"
                               Foreground="#64B5F6"
                               FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="(est. 3× margin relief)"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="9" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ── Toolbar ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="↻  Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="110" Height="30" Margin="0,0,10,0"/>
            <Button Content="↓  Export CSV"
                    Command="{Binding ExportToCsvCommand}"
                    Style="{StaticResource DangerButtonStyle}"
                    Width="120" Height="30"/>
        </StackPanel>

        <!-- ── Trade Log DataGrid ── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding TradeLog}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Style="{StaticResource DarkDataGridStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}"
                  RowHeight="32"
                  HeadersVisibility="Column">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Date"
                    Binding="{Binding Date, StringFormat={}{0:dd-MMM-yy}}"
                    Width="80" ElementStyle="{StaticResource CellCenter}"/>
                <DataGridTextColumn Header="Time"
                    Binding="{Binding Date, StringFormat={}{0:HH:mm:ss}}"
                    Width="72" ElementStyle="{StaticResource CellCenter}"/>

                <!-- EventType badge -->
                <DataGridTemplateColumn Header="Event" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EventType}" Value="SL_HIT">
                                                <Setter Property="Background" Value="#B71C1C"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="FLIP_BUY">
                                                <Setter Property="Background" Value="#E65100"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="FLIP_SELL">
                                                <Setter Property="Background" Value="#F57F17"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="ROLL">
                                                <Setter Property="Background" Value="#1B5E20"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="HEDGE_BUY">
                                                <Setter Property="Background" Value="#0D47A1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="HEDGE_EXIT">
                                                <Setter Property="Background" Value="#4A148C"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EventType}" Value="EXIT">
                                                <Setter Property="Background" Value="#424242"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EventType}" FontSize="10"
                                           FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Description"
                    Binding="{Binding LegDescription}"
                    Width="*" MinWidth="200"/>

                <DataGridTextColumn Header="Entry ₹"
                    Binding="{Binding EntryPrice, StringFormat=N2}"
                    Width="80" ElementStyle="{StaticResource CellRight}"/>
                <DataGridTextColumn Header="Exit ₹"
                    Binding="{Binding ExitPrice, StringFormat=N2}"
                    Width="80" ElementStyle="{StaticResource CellRight}"/>

                <!-- P&L column -->
                <DataGridTemplateColumn Header="P&amp;L ₹" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding PnL, StringFormat=N2}"
                                       TextAlignment="Right" Padding="0,0,6,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PnL, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cumulative P&L -->
                <DataGridTemplateColumn Header="Cum P&amp;L ₹" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CumulativePnL, StringFormat=N2}"
                                       TextAlignment="Right" Padding="0,0,6,0"
                                       VerticalAlignment="Center" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CumulativePnL, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Hedged"
                    Binding="{Binding WasHedged}"
                    Width="60" ElementStyle="{StaticResource CellCenter}"/>
                <DataGridTextColumn Header="Hedge Cost ₹"
                    Binding="{Binding HedgeCost, StringFormat=N2}"
                    Width="90" ElementStyle="{StaticResource CellRight}"/>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
