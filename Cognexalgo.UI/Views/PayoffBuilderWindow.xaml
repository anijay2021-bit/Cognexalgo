<Window x:Class="Cognexalgo.UI.Views.PayoffBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:local="clr-namespace:Cognexalgo.UI.Views"
        Title="Strategy Payoff Builder"
        Width="1340" Height="780"
        Background="#F2F4F8"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Surface"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Outline"   Color="#DEE2EA"/>
        <SolidColorBrush x:Key="Primary"   Color="#006B5E"/>
        <SolidColorBrush x:Key="OnPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="OnSurface" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="Muted"     Color="#72767E"/>
        <SolidColorBrush x:Key="Positive"  Color="#2E7D32"/>
        <SolidColorBrush x:Key="Negative"  Color="#C62828"/>
        <SolidColorBrush x:Key="Amber"     Color="#E65100"/>
        <SolidColorBrush x:Key="BgSubtle"  Color="#F2F4F8"/>

        <!-- Card border -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                      BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Metric card -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgSubtle}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="12,8"/>
        </Style>

        <!-- Labels -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
        </Style>

        <!-- Buttons -->
        <Style x:Key="FilledBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"      Value="{StaticResource OnPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TonalBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="#E0F2F1"/>
            <Setter Property="Foreground" Value="#006B5E"/>
        </Style>

        <Style x:Key="PaperBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Padding"    Value="16,8"/>
        </Style>

        <Style x:Key="LiveBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="#B71C1C"/>
            <Setter Property="Padding"    Value="16,8"/>
        </Style>

        <Style x:Key="RemoveBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#C62828"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4,0"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
        </Style>

        <!-- Strategy list item -->
        <Style x:Key="StrategyListItem" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8E6C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL — Strategy Categories ═══════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="14,12,14,10"
                        BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Strategy Picker"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurface}"/>
                        <TextBlock Text="Click a strategy to auto-fill legs"
                                   FontSize="10" Foreground="{StaticResource Muted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Controls: Index + Lots -->
                <Grid DockPanel.Dock="Top" Margin="14,10,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="INDEX"/>
                        <ComboBox Style="{StaticResource ComboStyle}"
                                  ItemsSource="{Binding Indices}"
                                  SelectedItem="{Binding SelectedIndex}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="LOTS"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding Lots, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Spot + ATM display -->
                <Grid DockPanel.Dock="Top" Margin="14,0,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SPOT PRICE (₹)"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding SpotPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="ATM"/>
                        <Border Background="{StaticResource BgSubtle}"
                                BorderBrush="{StaticResource Outline}" BorderThickness="1"
                                CornerRadius="4" Padding="6,5">
                            <TextBlock Text="{Binding AtmDisplay}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Primary}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Separator DockPanel.Dock="Top" Background="{StaticResource Outline}" Margin="0,0,0,4"/>

                <!-- Category lists (scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="8,4,8,8">

                        <Expander IsExpanded="True" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurface}"
                                           Text="🔵  Neutral"/>
                            </Expander.Header>
                            <ListBox x:Name="NeutralList"
                                     ItemsSource="{Binding NeutralStrategies}"
                                     SelectionChanged="OnStrategySelected"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StrategyListItem}"
                                     Margin="4,2,0,0"/>
                        </Expander>

                        <Expander Margin="0,6,0,0">
                            <Expander.Header>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurface}"
                                           Text="🟢  Bullish"/>
                            </Expander.Header>
                            <ListBox x:Name="BullishList"
                                     ItemsSource="{Binding BullishStrategies}"
                                     SelectionChanged="OnStrategySelected"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StrategyListItem}"
                                     Margin="4,2,0,0"/>
                        </Expander>

                        <Expander Margin="0,6,0,0">
                            <Expander.Header>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurface}"
                                           Text="🔴  Bearish"/>
                            </Expander.Header>
                            <ListBox x:Name="BearishList"
                                     ItemsSource="{Binding BearishStrategies}"
                                     SelectionChanged="OnStrategySelected"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StrategyListItem}"
                                     Margin="4,2,0,0"/>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ══ RIGHT PANEL ════════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
            <DockPanel>

                <!-- Top bar: Name + buttons -->
                <Grid DockPanel.Dock="Top" Margin="14,12,14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STRATEGY NAME"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding StrategyName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="+ Add Leg"
                            Style="{StaticResource TonalBtn}"
                            Command="{Binding AddLegCommand}"
                            VerticalAlignment="Bottom"/>
                    <Button Grid.Column="4" Content="📐 Calculate"
                            Style="{StaticResource FilledBtn}"
                            Command="{Binding CalculatePayoffCommand}"
                            VerticalAlignment="Bottom"/>
                </Grid>

                <Separator DockPanel.Dock="Top" Background="{StaticResource Outline}" Margin="0"/>

                <!-- 5-card metrics bar -->
                <UniformGrid DockPanel.Dock="Top" Rows="1" Columns="5"
                             Margin="14,10,14,8">

                    <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="Max Profit"/>
                            <TextBlock Style="{StaticResource MetricValue}"
                                       Text="{Binding MaxProfitDisplay}"
                                       Foreground="{StaticResource Positive}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="Max Loss"/>
                            <TextBlock Style="{StaticResource MetricValue}"
                                       Text="{Binding MaxLossDisplay}"
                                       Foreground="{StaticResource Negative}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="Net Credit / Debit"/>
                            <TextBlock Style="{StaticResource MetricValue}"
                                       Text="{Binding NetCreditDisplay}"
                                       Foreground="{StaticResource Primary}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="Breakevens"/>
                            <TextBlock Style="{StaticResource MetricValue}" FontSize="12"
                                       Text="{Binding BreakevenDisplay}"
                                       Foreground="{StaticResource Amber}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="POP (at expiry)"/>
                            <TextBlock Style="{StaticResource MetricValue}"
                                       Text="{Binding PopDisplay}"
                                       Foreground="{StaticResource Positive}"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Separator DockPanel.Dock="Top" Background="{StaticResource Outline}" Margin="0"/>

                <!-- Footer buttons -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="🧪  Deploy Paper"
                                    Style="{StaticResource PaperBtn}"
                                    Command="{Binding DeployPaperCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="🔴  Deploy Live"
                                    Style="{StaticResource LiveBtn}"
                                    Command="{Binding DeployLiveCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Clear"
                                    Style="{StaticResource TonalBtn}"
                                    Command="{Binding ClearLegsCommand}"/>
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{StaticResource Muted}"
                                   Text="Double-click a cell to edit  ·  ✕ to remove leg"/>
                    </Grid>
                </Border>

                <!-- Legs DataGrid -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
                    <DataGrid ItemsSource="{Binding Legs}"
                              SelectedItem="{Binding SelectedLeg}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="34" MaxHeight="180"
                              BorderThickness="0"
                              Background="{StaticResource Surface}">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"  Value="#F2F4F8"/>
                                <Setter Property="Padding"     Value="8,5"/>
                                <Setter Property="FontSize"    Value="10"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                                <Setter Property="Foreground"  Value="{StaticResource Muted}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="Action" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Action}"
                                                   VerticalAlignment="Center" Margin="8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PayoffBuilderWindow.ActionOptions}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Type" Width="58">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OptionType}"
                                                   VerticalAlignment="Center" Margin="8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding OptionType, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static local:PayoffBuilderWindow.OptionTypeOptions}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Strike" Width="80"
                                               Binding="{Binding Strike, StringFormat=N0}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Premium ₹" Width="90"
                                               Binding="{Binding Premium, StringFormat=N2}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin"              Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Lots" Width="50"
                                               Binding="{Binding Lots}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Index" Width="80"
                                               Binding="{Binding Index}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="8,0"/>
                                        <Setter Property="Foreground"        Value="{StaticResource Muted}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Expiry" Width="64"
                                               Binding="{Binding Expiry}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="8,0"/>
                                        <Setter Property="Foreground"        Value="{StaticResource Muted}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource RemoveBtn}" Content="✕"
                                                Command="{Binding DataContext.RemoveLegCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Payoff Chart — fills remaining space -->
                <DockPanel Margin="14,8,14,4">

                    <TextBlock DockPanel.Dock="Top"
                               Text="Payoff at Expiry"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurface}"
                               Margin="0,0,0,2"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="X-axis: underlying price at expiry   |   Y-axis: net P&amp;L (₹)"
                               FontSize="10" Foreground="{StaticResource Muted}"
                               Margin="0,0,0,6"/>

                    <syncfusion:SfChart Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch">

                        <syncfusion:SfChart.PrimaryAxis>
                            <syncfusion:NumericalAxis Header="Underlying Price (₹)"
                                                      LabelFormat="N0"
                                                      ShowGridLines="True"/>
                        </syncfusion:SfChart.PrimaryAxis>

                        <syncfusion:SfChart.SecondaryAxis>
                            <syncfusion:NumericalAxis Header="P&amp;L (₹)"
                                                      LabelFormat="N0"
                                                      ShowGridLines="True"/>
                        </syncfusion:SfChart.SecondaryAxis>

                        <!-- Profit zone (green) -->
                        <syncfusion:SplineAreaSeries
                            ItemsSource="{Binding ProfitData}"
                            XBindingPath="Price" YBindingPath="Pnl"
                            Interior="#302E7D32"
                            Stroke="#2E7D32" StrokeThickness="2"/>

                        <!-- Loss zone (red) -->
                        <syncfusion:SplineAreaSeries
                            ItemsSource="{Binding LossData}"
                            XBindingPath="Price" YBindingPath="Pnl"
                            Interior="#30C62828"
                            Stroke="#C62828" StrokeThickness="2"/>

                        <syncfusion:SfChart.Annotations>
                            <syncfusion:HorizontalLineAnnotation Y1="0"
                                Stroke="#AAAAAA" StrokeThickness="1.2"
                                StrokeDashArray="4,3"/>
                            <syncfusion:VerticalLineAnnotation
                                X1="{Binding SpotPrice}"
                                Stroke="#FF9800" StrokeThickness="2"
                                StrokeDashArray="5,3" Text="Spot"/>
                        </syncfusion:SfChart.Annotations>

                    </syncfusion:SfChart>
                </DockPanel>

            </DockPanel>
        </Border>

    </Grid>
</Window>
