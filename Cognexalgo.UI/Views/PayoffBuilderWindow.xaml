<Window x:Class="Cognexalgo.UI.Views.PayoffBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:local="clr-namespace:Cognexalgo.UI.Views"
        Title="Strategy Payoff Builder"
        Width="1260" Height="760"
        Background="#F5F5F7"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- colours matching MainWindow Material3 tokens -->
        <SolidColorBrush x:Key="Surface"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Outline"    Color="#DEE2EA"/>
        <SolidColorBrush x:Key="Primary"    Color="#006B5E"/>
        <SolidColorBrush x:Key="OnPrimary"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="OnSurface"  Color="#1A1C1E"/>
        <SolidColorBrush x:Key="Muted"      Color="#72767E"/>
        <SolidColorBrush x:Key="Positive"   Color="#2E7D32"/>
        <SolidColorBrush x:Key="Negative"   Color="#C62828"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.07" BlurRadius="12"
                                      ShadowDepth="3" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Foreground"     Value="{StaticResource Muted}"/>
            <Setter Property="Margin"         Value="0,0,0,4"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
        </Style>

        <Style x:Key="FilledBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"   Value="{StaticResource OnPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TonalBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="#E0F2F1"/>
            <Setter Property="Foreground" Value="#006B5E"/>
        </Style>

        <Style x:Key="DeployBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Padding"    Value="20,10"/>
        </Style>

        <Style x:Key="RemoveBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#C62828"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4,0"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL ══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
            <DockPanel>

                <!-- Header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Strategy Builder"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource OnSurface}"
                           Margin="0,0,0,14"/>

                <!-- Strategy Name -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource SectionLabel}" Text="STRATEGY NAME"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding StrategyName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Index + Template row -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="INDEX"/>
                        <ComboBox Style="{StaticResource ComboStyle}"
                                  ItemsSource="{Binding Indices}"
                                  SelectedItem="{Binding SelectedIndex}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TEMPLATE"/>
                        <ComboBox Style="{StaticResource ComboStyle}"
                                  ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplate}"/>
                    </StackPanel>
                </Grid>

                <!-- Spot Price + Load Template -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="SPOT PRICE (₹)"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding SpotPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="↺  Load Template"
                            Style="{StaticResource TonalBtn}"
                            Command="{Binding LoadTemplateCommand}"
                            VerticalAlignment="Bottom" Margin="0,0,0,0"/>
                </Grid>

                <!-- Legs header row -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="LEGS" Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Content="+ Add Leg"
                            Style="{StaticResource TonalBtn}"
                            Command="{Binding AddLegCommand}"
                            Padding="10,5" FontSize="12"/>
                </Grid>

                <!-- Legs DataGrid -->
                <DataGrid DockPanel.Dock="Top"
                          ItemsSource="{Binding Legs}"
                          SelectedItem="{Binding SelectedLeg}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="36"
                          MaxHeight="230"
                          BorderBrush="{StaticResource Outline}"
                          BorderThickness="1"
                          Background="{StaticResource Surface}"
                          Margin="0,0,0,12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"  Value="#F2F4F8"/>
                            <Setter Property="Padding"     Value="6,6"/>
                            <Setter Property="FontSize"    Value="11"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="Foreground"  Value="{StaticResource Muted}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <!-- Action -->
                        <DataGridTemplateColumn Header="Action" Width="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Action}" VerticalAlignment="Center" Margin="6,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{x:Static local:PayoffBuilderWindow.ActionOptions}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Option Type -->
                        <DataGridTemplateColumn Header="Type" Width="58">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OptionType}" VerticalAlignment="Center" Margin="6,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding OptionType, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{x:Static local:PayoffBuilderWindow.OptionTypeOptions}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Strike -->
                        <DataGridTextColumn Header="Strike" Width="80"
                            Binding="{Binding Strike, StringFormat=N0}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Premium -->
                        <DataGridTextColumn Header="Premium ₹" Width="84"
                            Binding="{Binding Premium, StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Lots -->
                        <DataGridTextColumn Header="Lots" Width="50"
                            Binding="{Binding Lots}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Remove -->
                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RemoveBtn}" Content="✕"
                                            Command="{Binding DataContext.RemoveLegCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Calculate button -->
                <Button DockPanel.Dock="Top"
                        Content="📐  Calculate Payoff"
                        Style="{StaticResource TonalBtn}"
                        Command="{Binding CalculatePayoffCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="0,9" FontSize="13"
                        Margin="0,0,0,14"/>

                <!-- Metrics -->
                <Border DockPanel.Dock="Top"
                        Background="#F2F4F8" CornerRadius="8"
                        Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetricLabel}" Text="Max Profit"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right"
                                   Style="{StaticResource MetricValue}"
                                   Text="{Binding MaxProfitDisplay}"
                                   Foreground="{StaticResource Positive}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetricLabel}" Text="Max Loss"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right"
                                   Style="{StaticResource MetricValue}"
                                   Text="{Binding MaxLossDisplay}"
                                   Foreground="{StaticResource Negative}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetricLabel}" Text="Breakevens"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right"
                                   Style="{StaticResource MetricValue}" FontSize="13"
                                   Text="{Binding BreakevenDisplay}"
                                   Foreground="#E65100" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Deploy button (fills remaining space at bottom) -->
                <Button DockPanel.Dock="Bottom"
                        Content="▶  Deploy to Engine"
                        Style="{StaticResource DeployBtn}"
                        Command="{Binding DeployToEngineCommand}"
                        HorizontalAlignment="Stretch"/>

            </DockPanel>
        </Border>

        <!-- ══ RIGHT PANEL — Payoff Chart ════════════════════════════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
            <DockPanel>

                <TextBlock DockPanel.Dock="Top"
                           Text="Payoff at Expiry"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource OnSurface}"
                           Margin="0,0,0,4"/>

                <TextBlock DockPanel.Dock="Top"
                           Text="X-axis: Underlying price at expiry   |   Y-axis: Net P&amp;L (₹)"
                           FontSize="11" Foreground="{StaticResource Muted}"
                           Margin="0,0,0,14"/>

                <syncfusion:SfChart DockPanel.Dock="Top"
                                    Background="Transparent"
                                    Margin="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">

                    <syncfusion:SfChart.PrimaryAxis>
                        <syncfusion:NumericalAxis Header="Underlying Price (₹)"
                                                  LabelFormat="N0"
                                                  ShowGridLines="True"/>
                    </syncfusion:SfChart.PrimaryAxis>

                    <syncfusion:SfChart.SecondaryAxis>
                        <syncfusion:NumericalAxis Header="P&amp;L (₹)"
                                                  LabelFormat="N0"
                                                  ShowGridLines="True"/>
                    </syncfusion:SfChart.SecondaryAxis>

                    <!-- Profit zone (green area above zero) -->
                    <syncfusion:SplineAreaSeries
                        ItemsSource="{Binding ProfitData}"
                        XBindingPath="Price" YBindingPath="Pnl"
                        Interior="#2E7D3228"
                        Stroke="#2E7D32"
                        StrokeThickness="2"/>

                    <!-- Loss zone (red area below zero) -->
                    <syncfusion:SplineAreaSeries
                        ItemsSource="{Binding LossData}"
                        XBindingPath="Price" YBindingPath="Pnl"
                        Interior="#C6282828"
                        Stroke="#C62828"
                        StrokeThickness="2"/>

                    <!-- Annotations: zero line + current spot -->
                    <syncfusion:SfChart.Annotations>
                        <syncfusion:HorizontalLineAnnotation Y1="0"
                            Stroke="#888888" StrokeThickness="1.2"
                            StrokeDashArray="4,3"/>
                        <syncfusion:VerticalLineAnnotation X1="{Binding SpotPrice}"
                            Stroke="#FF9800" StrokeThickness="2"
                            StrokeDashArray="5,3"
                            Text="Spot"/>
                    </syncfusion:SfChart.Annotations>

                </syncfusion:SfChart>

            </DockPanel>
        </Border>

    </Grid>
</Window>
