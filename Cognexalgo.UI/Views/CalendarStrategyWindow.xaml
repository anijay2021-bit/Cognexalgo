<Window x:Class="Cognexalgo.UI.Views.CalendarStrategyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        Title="Calendar Spread Strategy"
        Width="900" Height="830"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Config card -->
                <RowDefinition Height="Auto"/>  <!-- Hedge section -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
                <RowDefinition Height="Auto"/>  <!-- Status bar -->
                <RowDefinition Height="Auto"/>  <!-- Leg DataGrid -->
                <RowDefinition Height="Auto"/>  <!-- Event log label -->
                <RowDefinition Height="150"/>   <!-- Event log -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <TextBlock Grid.Row="0"
                       Text="CALENDAR SPREAD STRATEGY"
                       Style="{StaticResource HeaderTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- ── Config Card ── -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="18,14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Strategy Name"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="0" Grid.Column="1"
                               Text="{Binding StrategyName, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Symbol"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <ComboBox  Grid.Row="0" Grid.Column="4"
                               ItemsSource="{Binding SymbolOptions}"
                               SelectedItem="{Binding Symbol}"
                               Margin="0,0,0,6"/>

                    <!-- Row 1 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="First Entry Time (HH:mm)"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1"
                               Text="{Binding FirstEntryTime, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="No. of Lots"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="4"
                               Text="{Binding Lots, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Buy SL %"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding BuySLPercent, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Timeframe (min)"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <ComboBox  Grid.Row="2" Grid.Column="4"
                               ItemsSource="{Binding TimeframeOptions}"
                               SelectedItem="{Binding Timeframe}"
                               Margin="0,0,0,6"/>

                    <!-- Row 3 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Weekly Exit Time (HH:mm)"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="3" Grid.Column="1"
                               Text="{Binding WeeklyExpiryExitTime, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Enable Buy SL on Candle Close"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="3" Grid.Column="4"
                               IsChecked="{Binding EnableBuySLOnCandleClose}"
                               Foreground="{StaticResource TextMainBrush}"
                               VerticalAlignment="Center" Margin="2,0,0,6"/>

                    <!-- Row 4 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Profit ₹"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="4" Grid.Column="1"
                               Text="{Binding MaxProfit, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Max Loss ₹"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="4" Grid.Column="4"
                               Text="{Binding MaxLoss, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,6"/>

                    <!-- Row 5 -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Live Mode"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <CheckBox  Grid.Row="5" Grid.Column="1"
                               IsChecked="{Binding IsLiveMode}"
                               Foreground="{StaticResource TextMainBrush}"
                               VerticalAlignment="Center" Margin="2,0,0,4"/>
                </Grid>
            </Border>

            <!-- ── Hedge Section ── -->
            <Border Grid.Row="2"
                    Background="#1A2744" CornerRadius="4"
                    Padding="12,10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding EnableHedgeBuying}"
                              Content="Enable Hedge Buying (1 day before expiry)"
                              Foreground="{StaticResource TextMainBrush}"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              Margin="0,0,24,0"/>
                    <TextBlock Text="Strike Offset (1–10):"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               FontSize="11"/>
                    <ComboBox ItemsSource="{Binding HedgeOffsetOptions}"
                              SelectedValue="{Binding HedgeStrikeOffset}"
                              Width="70" Margin="8,0,0,0"
                              IsEnabled="{Binding EnableHedgeBuying}"/>
                    <TextBlock Text="strikes away from sell strike"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" FontSize="11"/>
                    <Border Background="#0D47A1" CornerRadius="4"
                            Padding="8,4" Margin="24,0,0,0"
                            Visibility="{Binding HedgeActive, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⚡ HEDGE ACTIVE"
                                   Foreground="#64B5F6"
                                   FontWeight="Bold" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Buttons Row ── -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="▶  Start Strategy"
                        Command="{Binding StartStrategyCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160" Height="34" Margin="0,0,10,0"/>
                <Button Content="■  Stop Strategy"
                        Command="{Binding StopStrategyCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Width="160" Height="34"/>
            </StackPanel>

            <!-- ── Status Bar (5 boxes) ── -->
            <Border Grid.Row="4"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14,10"
                    Margin="0,0,0,10">
                <UniformGrid Rows="1" Columns="5">

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Phase" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding Phase}"
                                   Foreground="#00BCD4" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="ATM Strike" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding AtmStrike, StringFormat=N0}"
                                   Foreground="{StaticResource TextMainBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Combined Sell Entry" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding CombinedSellEntry, StringFormat='₹{0:N2}'}"
                                   Foreground="{StaticResource TextMainBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Unrealized P&amp;L" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding UnrealizedPnL, StringFormat='₹{0:N2}'}"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UnrealizedPnL, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Total P&amp;L" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock FontSize="16" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding TotalPnL, StringFormat='₹{0:N2}'}"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalPnL, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                </UniformGrid>
            </Border>

            <!-- ── Leg Status DataGrid ── -->
            <DataGrid Grid.Row="5"
                      ItemsSource="{Binding LegRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{StaticResource DarkDataGridStyle}"
                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                      Margin="0,0,0,10"
                      MaxHeight="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Leg"    Binding="{Binding Leg}"                        Width="140"/>
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}"                     Width="90"/>
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}"                     Width="*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}"                     Width="85"/>
                    <DataGridTextColumn Header="Entry"  Binding="{Binding Entry,  StringFormat=N2}"    Width="70"/>
                    <DataGridTextColumn Header="LTP"    Binding="{Binding Ltp,    StringFormat=N2}"    Width="70"/>
                    <DataGridTextColumn Header="SL"     Binding="{Binding SL,     StringFormat=N2}"    Width="70"/>
                    <DataGridTextColumn Header="P&amp;L" Binding="{Binding PnL,   StringFormat=N2}"   Width="75"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Event Log label ── -->
            <TextBlock Grid.Row="6"
                       Text="Event Log"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <!-- ── Event Log ── -->
            <ListBox Grid.Row="7"
                     ItemsSource="{Binding EventLog}"
                     Background="#0D1117"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="Consolas"
                     FontSize="11"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

        </Grid>
    </ScrollViewer>
</Window>
