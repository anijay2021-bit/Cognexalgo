<Window x:Class="Cognexalgo.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="500" Width="400"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterOwner">
    <Border Background="{StaticResource BackgroundBrush}" Padding="20">
        <StackPanel>
            <TextBlock Text="BROKER SETTINGS (ANGEL ONE)" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,20"/>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="API Key" Style="{StaticResource LabelTextStyle}"/>
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBoxStyle}"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Client Code" Style="{StaticResource LabelTextStyle}"/>
                <TextBox Text="{Binding ClientCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBoxStyle}"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Password" Style="{StaticResource LabelTextStyle}"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBoxStyle}"/> <!-- PasswordBox requires binding helper, using TextBox for MVP simplicity or upgrade later -->
            </StackPanel>
            
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="TOTP Key" Style="{StaticResource LabelTextStyle}"/>
                <TextBox Text="{Binding TotpKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBoxStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CANCEL" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="SAVE SETTINGS" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
