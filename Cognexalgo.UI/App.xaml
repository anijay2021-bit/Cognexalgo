<Application x:Class="Cognexalgo.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Cognexalgo.UI"
             xmlns:converters="clr-namespace:Cognexalgo.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/SilverTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:RadioButtonConverter x:Key="RadioButtonConverter"/>
            <converters:OptionTypeToColorConverter x:Key="OptionTypeToColorConverter"/>
            <converters:ActionToColorConverter x:Key="ActionToColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
