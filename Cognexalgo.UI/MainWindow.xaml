<Window x:Class="Cognexalgo.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        xmlns:conv="clr-namespace:Cognexalgo.UI.Converters"
        mc:Ignorable="d"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=Material3Light}"
        Title="Cognexalgo — Live Operations"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7"
        FontFamily="Segoe UI Variable, Inter, Segoe UI, sans-serif"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <conv:IsNegativeConverter       x:Key="IsNegativeConverter"/>
        <conv:StatusBackgroundConverter x:Key="StatusBgConverter"/>
        <conv:StatusForegroundConverter x:Key="StatusFgConverter"/>
        <conv:LogColorConverter         x:Key="LogColorConverter"/>
        <conv:GridLengthConverter       x:Key="GridLengthConverter"/>
        <BooleanToVisibilityConverter   x:Key="BoolToVis"/>

        <!-- MATERIAL 3 LIGHT COLOUR TOKENS -->
        <SolidColorBrush x:Key="Surface"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceVariant"   Color="#F2F4F8"/>
        <SolidColorBrush x:Key="SurfaceContainer" Color="#EEF1F6"/>
        <SolidColorBrush x:Key="PageBg"           Color="#F5F5F7"/>
        <SolidColorBrush x:Key="Outline"          Color="#DEE2EA"/>
        <SolidColorBrush x:Key="Primary"          Color="#006B5E"/>
        <SolidColorBrush x:Key="PrimaryLight"     Color="#E0F2F1"/>
        <SolidColorBrush x:Key="OnPrimary"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Positive"         Color="#2E7D32"/>
        <SolidColorBrush x:Key="PositiveLight"    Color="#E8F5E9"/>
        <SolidColorBrush x:Key="Negative"         Color="#C62828"/>
        <SolidColorBrush x:Key="NegativeLight"    Color="#FFEBEE"/>
        <SolidColorBrush x:Key="Warning"          Color="#E65100"/>
        <SolidColorBrush x:Key="WarningLight"     Color="#FFF3E0"/>
        <SolidColorBrush x:Key="OnSurface"        Color="#1A1C1E"/>
        <SolidColorBrush x:Key="OnSurfaceVar"     Color="#44474F"/>
        <SolidColorBrush x:Key="Muted"            Color="#72767E"/>

        <!-- ELEVATED CARD -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.07" BlurRadius="12" ShadowDepth="3" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KPI TILE -->
        <Style x:Key="KpiTile" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Outline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="16"/>
            <Setter Property="Padding"         Value="20,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="14" ShadowDepth="4" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FILLED BUTTON -->
        <Style x:Key="FilledBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"      Value="{StaticResource OnPrimary}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.87"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TonalBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
        </Style>

        <Style x:Key="ErrorBtn" TargetType="Button" BasedOn="{StaticResource FilledBtn}">
            <Setter Property="Background" Value="{StaticResource Negative}"/>
        </Style>

        <!-- M3 TAB STYLE -->
        <Style x:Key="M3Tab" TargetType="TabItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource OnSurfaceVar}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="20,12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,3"
                                Margin="0,0,2,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource PageBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="{Binding LogPanelHeight, Mode=TwoWay, Converter={StaticResource GridLengthConverter}}"/>
        </Grid.RowDefinitions>

        <!-- ─── HERO HEADER ──────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
            <Grid Margin="24,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="◆ COGNEX" FontSize="18"
                               Foreground="{StaticResource Primary}" HorizontalAlignment="Left"/>
                    <TextBlock Text="LIVE OPERATIONS" Foreground="{StaticResource Muted}"
                               FontSize="8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>

                <Separator Grid.Column="1" Width="1" Background="{StaticResource Outline}" Margin="0,6"/>

                <!-- 5 KPI tiles -->
                <UniformGrid Grid.Column="2" Columns="5">
                    <Border Style="{StaticResource KpiTile}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="PORTFOLIO MTM" Foreground="{StaticResource Muted}" FontSize="10"/>
                            <TextBlock Text="{Binding TotalMtm, StringFormat=₹{0:N0}}" FontSize="24" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalMtm, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Today's P&amp;L" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiTile}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="ACTIVE" Foreground="{StaticResource Muted}" FontSize="10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource Positive}" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="{Binding RunningStrategiesCount}" Foreground="{StaticResource Primary}" FontSize="24"/>
                            </StackPanel>
                            <TextBlock Text="Strategies" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiTile}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="POSITIONS" Foreground="{StaticResource Muted}" FontSize="10"/>
                            <TextBlock Text="{Binding Positions.Count}" Foreground="{StaticResource OnSurface}" FontSize="24" Margin="0,4,0,0"/>
                            <TextBlock Text="Open legs" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiTile}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="PENDING" Foreground="{StaticResource Muted}" FontSize="10"/>
                            <TextBlock Text="{Binding PendingOrdersCount}" Foreground="{StaticResource Warning}" FontSize="24" Margin="0,4,0,0"/>
                            <TextBlock Text="Orders" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiTile}">
                        <StackPanel>
                            <TextBlock Text="EXITED" Foreground="{StaticResource Muted}" FontSize="10"/>
                            <TextBlock Text="{Binding ExitedStrategiesCount}" Foreground="{StaticResource OnSurface}" FontSize="24" Margin="0,4,0,0"/>
                            <TextBlock Text="Today" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Right controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- Connect / Connected toggle button -->
                    <Button Command="{Binding StartEngineCommand}" Margin="0,0,10,0" Padding="14,8" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilledBtn}">
                                <Setter Property="Content"     Value="⚡  Connect"/>
                                <Setter Property="Background"  Value="{StaticResource Primary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEngineRunning}" Value="True">
                                        <Setter Property="Content"    Value="● Connected"/>
                                        <Setter Property="Background" Value="#43A047"/>
                                        <Setter Property="IsEnabled"  Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⏻  Kill All" Style="{StaticResource ErrorBtn}" Command="{Binding KillSwitchCommand}" Margin="0,0,10,0"/>
                    <Button Content="⚙" Style="{StaticResource TonalBtn}" Command="{Binding OpenSettingsCommand}" Padding="12,8" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── TAB CONTENT ───────────────────────────────── -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Surface}"
                                BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="16,0">
                                <TabPanel IsItemsHost="True"/>
                            </StackPanel>
                        </Border>
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <!-- DASHBOARD -->
            <TabItem Style="{StaticResource M3Tab}" Header="⊞  Dashboard">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="310"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="Intraday P&amp;L" Foreground="{StaticResource OnSurface}" FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalMtm, StringFormat=  ₹{0:N0}}" FontSize="15" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TotalMtm, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <syncfusion:SfChart Grid.Row="1" Background="Transparent">
                                <syncfusion:SfChart.PrimaryAxis>
                                    <syncfusion:DateTimeAxis ShowGridLines="False" AxisLineStyle="{x:Null}" LabelFormat="HH:mm"/>
                                </syncfusion:SfChart.PrimaryAxis>
                                <syncfusion:SfChart.SecondaryAxis>
                                    <syncfusion:NumericalAxis ShowGridLines="True" AxisLineStyle="{x:Null}"/>
                                </syncfusion:SfChart.SecondaryAxis>
                                <syncfusion:SplineAreaSeries ItemsSource="{Binding PnlHistory}"
                                    XBindingPath="Time" YBindingPath="Value"
                                    Interior="#006B5E12" Stroke="#006B5E" StrokeThickness="2.5"/>
                            </syncfusion:SfChart>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Live Strategies" Foreground="{StaticResource OnSurface}"
                                       FontSize="15" Margin="0,0,0,12"/>
                            <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding Strategies}"
                                AutoGenerateColumns="False" HeaderRowHeight="30" RowHeight="40"
                                Background="Transparent" BorderThickness="0">
                                <syncfusion:SfDataGrid.Columns>
                                    <syncfusion:GridTextColumn HeaderText="Name"    MappingName="Name"   Width="160"/>
                                    <syncfusion:GridTextColumn HeaderText="P&amp;L" MappingName="Pnl"   Width="100" TextAlignment="Right"/>
                                    <syncfusion:GridTextColumn HeaderText="Status"  MappingName="Status" Width="80"/>
                                </syncfusion:SfDataGrid.Columns>
                            </syncfusion:SfDataGrid>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="+ New Strategy" Style="{StaticResource FilledBtn}" Command="{Binding AddStrategyCommand}" Padding="14,7" FontSize="12"/>
                                <Button Content="📊 Reports" Style="{StaticResource TonalBtn}" Command="{Binding OpenReportsCommand}" Margin="8,0,0,0" Padding="14,7" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- STRATEGIES -->
            <TabItem Style="{StaticResource M3Tab}" Header="◈  Strategies">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SurfaceVariant}" Padding="16,10"
                            BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ New Strategy" Style="{StaticResource FilledBtn}" Command="{Binding AddStrategyCommand}" Margin="0,0,10,0"/>
                            <Button Content="⟳ Refresh" Style="{StaticResource TonalBtn}" Command="{Binding RefreshStrategiesCommand}"/>
                        </StackPanel>
                    </Border>
                    <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding Strategies}"
                        AutoGenerateColumns="False" AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                        HeaderRowHeight="38" RowHeight="50" GridLinesVisibility="Horizontal" Background="{StaticResource PageBg}">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="ID"         MappingName="Id"                 Width="60"  TextAlignment="Center"/>
                            <syncfusion:GridTextColumn HeaderText="Strategy"   MappingName="Name"               Width="220"/>
                            <syncfusion:GridTextColumn HeaderText="Instrument" MappingName="InstrumentType"     Width="120"/>
                            <syncfusion:GridTextColumn HeaderText="Status"     MappingName="Status"             Width="110"/>
                            <syncfusion:GridTextColumn HeaderText="Mode"       MappingName="TradingModeDisplay" Width="90"  TextAlignment="Center"/>
                            <syncfusion:GridTextColumn HeaderText="P&amp;L"   MappingName="Pnl"                Width="120" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                            <syncfusion:GridTextColumn HeaderText="LTP"        MappingName="Ltp"                Width="100" TextAlignment="Right" DisplayBinding="{Binding Ltp, StringFormat=N2}"/>
                            <syncfusion:GridTextColumn HeaderText="Entry"      MappingName="EntryTime"          Width="90"  DisplayBinding="{Binding EntryTime, StringFormat=HH:mm:ss}"/>
                            <syncfusion:GridTemplateColumn HeaderText="Actions" MappingName="Actions"           Width="220">
                                <syncfusion:GridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                            <!-- Deploy / Deployed toggle button -->
                                            <Button Command="{Binding DataContext.StartV2StrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,4" Margin="0,0,6,0" FontSize="11">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FilledBtn}">
                                                        <Setter Property="Content"    Value="▶ Deploy"/>
                                                        <Setter Property="Background" Value="#E53935"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDeployed}" Value="True">
                                                                <Setter Property="Content"    Value="✓ Deployed"/>
                                                                <Setter Property="Background" Value="#43A047"/>
                                                                <Setter Property="IsEnabled"  Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="■ Stop"
                                                    Command="{Binding DataContext.StopV2StrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource TonalBtn}" Padding="10,4" Margin="0,0,6,0" FontSize="11"/>
                                            <Button Content="✎"
                                                    Command="{Binding DataContext.EditStrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource TonalBtn}" Padding="10,4" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </syncfusion:GridTemplateColumn.CellTemplate>
                            </syncfusion:GridTemplateColumn>
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                    <Border Grid.Row="2" Background="{StaticResource SurfaceVariant}" Padding="16,8"
                            BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Portfolio P&amp;L  " Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalV2Pnl, StringFormat=₹{0:N0}}" FontSize="18" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Positive}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalV2Pnl, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Negative}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- POSITIONS -->
            <TabItem Style="{StaticResource M3Tab}" Header="▤  Positions">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,6">
                        <Button Content="⟳ Refresh" Style="{StaticResource TonalBtn}"
                                Command="{Binding FetchPositionsCommand}" Padding="10,4" FontSize="11" Margin="0,0,8,0"/>
                        <Button Content="🗑 Clear All" Style="{StaticResource ErrorBtn}"
                                Command="{Binding ClearPositionsCommand}" Padding="10,4" FontSize="11"/>
                    </StackPanel>
                <syncfusion:SfDataGrid ItemsSource="{Binding Positions}" AutoGenerateColumns="False"
                    AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                    HeaderRowHeight="38" RowHeight="46" GridLinesVisibility="Horizontal" Background="{StaticResource PageBg}">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn HeaderText="Symbol"     MappingName="TradingSymbol"  Width="170"/>
                        <syncfusion:GridTextColumn HeaderText="Net Qty"    MappingName="NetQty"         Width="80"  TextAlignment="Right"/>
                        <syncfusion:GridTextColumn HeaderText="P&amp;L"   MappingName="Pnl"            Width="120" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                        <syncfusion:GridTextColumn HeaderText="Status"     MappingName="Status"         Width="100"/>
                        <syncfusion:GridTextColumn HeaderText="LTP"        MappingName="Ltp"            Width="100" TextAlignment="Right" DisplayBinding="{Binding Ltp, StringFormat=N2}"/>
                        <syncfusion:GridTextColumn HeaderText="Entry"      MappingName="AvgNetPrice"    Width="100" TextAlignment="Right" DisplayBinding="{Binding AvgNetPrice, StringFormat=N2}"/>
                        <syncfusion:GridTextColumn HeaderText="Stop Loss"  MappingName="StopLoss"       Width="100" TextAlignment="Right" DisplayBinding="{Binding StopLoss, StringFormat=N2}"/>
                        <syncfusion:GridTextColumn HeaderText="Target"     MappingName="Target"         Width="100" TextAlignment="Right" DisplayBinding="{Binding Target, StringFormat=N2}"/>
                        <syncfusion:GridTextColumn HeaderText="IV%"        MappingName="IV"             Width="70"  TextAlignment="Right" DisplayBinding="{Binding IV, StringFormat=F1}"/>
                        <syncfusion:GridTextColumn HeaderText="Δ Delta"    MappingName="Delta"          Width="80"  TextAlignment="Right" DisplayBinding="{Binding Delta, StringFormat=F3}"/>
                        <syncfusion:GridTextColumn HeaderText="Θ Theta"    MappingName="Theta"          Width="80"  TextAlignment="Right" DisplayBinding="{Binding Theta, StringFormat=F2}"/>
                        <syncfusion:GridTextColumn HeaderText="Vega"       MappingName="Vega"           Width="70"  TextAlignment="Right" DisplayBinding="{Binding Vega, StringFormat=F2}"/>
                        <syncfusion:GridTemplateColumn HeaderText="Action" MappingName="Action"         Width="100">
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Exit" Style="{StaticResource ErrorBtn}"
                                            Command="{Binding DataContext.ExitPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Padding="14,5" FontSize="12"/>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>
                </DockPanel>
            </TabItem>

            <!-- ORDERS -->
            <TabItem Style="{StaticResource M3Tab}" Header="⇄  Orders">
                <syncfusion:SfDataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False"
                    AllowResizingColumns="True" AllowSorting="True" AllowFiltering="True"
                    HeaderRowHeight="38" RowHeight="42" GridLinesVisibility="Horizontal" Background="{StaticResource PageBg}">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn HeaderText="Time"     MappingName="Timestamp"       Width="90"  DisplayBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                        <syncfusion:GridTextColumn HeaderText="Order ID" MappingName="OrderId"         Width="120"/>
                        <syncfusion:GridTextColumn HeaderText="Type"     MappingName="TransactionType" Width="80"  TextAlignment="Center"/>
                        <syncfusion:GridTextColumn HeaderText="Symbol"   MappingName="Symbol"          Width="170"/>
                        <syncfusion:GridTextColumn HeaderText="Qty"      MappingName="Qty"             Width="80"  TextAlignment="Right"/>
                        <syncfusion:GridTextColumn HeaderText="Price"    MappingName="Price"           Width="100" TextAlignment="Right" DisplayBinding="{Binding Price, StringFormat=₹{0:N2}}"/>
                        <syncfusion:GridTextColumn HeaderText="Status"   MappingName="Status"          Width="110"/>
                        <syncfusion:GridTextColumn HeaderText="Strategy" MappingName="StrategyName"    Width="160"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>
            </TabItem>

            <!-- OPTION CHAIN -->
            <TabItem Style="{StaticResource M3Tab}" Header="Ω  Option Chain">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SurfaceVariant}" Padding="16,10"
                            BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Index  " Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            <ComboBox Width="140" SelectedItem="{Binding SelectedOptionIndex}" Margin="0,0,14,0">
                                <ComboBoxItem>NIFTY</ComboBoxItem>
                                <ComboBoxItem>BANKNIFTY</ComboBoxItem>
                                <ComboBoxItem>FINNIFTY</ComboBoxItem>
                            </ComboBox>
                            <Button Content="Load Chain" Style="{StaticResource FilledBtn}" Command="{Binding FetchOptionChainCommand}" Margin="0,0,24,0"/>
                            <TextBlock Text="Spot  " Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SpotPrice, StringFormat=₹{0:N2}}" Foreground="{StaticResource Primary}" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding OptionChain}" AutoGenerateColumns="False"
                        AllowSorting="True" HeaderRowHeight="38" RowHeight="40" GridLinesVisibility="Horizontal" Background="{StaticResource PageBg}">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Strike"  MappingName="Strike"       Width="100" TextAlignment="Right"/>
                            <syncfusion:GridTextColumn HeaderText="Type"    MappingName="OptionType"   Width="70"  TextAlignment="Center"/>
                            <syncfusion:GridTextColumn HeaderText="LTP"     MappingName="LTP"          Width="100" TextAlignment="Right" DisplayBinding="{Binding LTP, StringFormat=N2}"/>
                            <syncfusion:GridTextColumn HeaderText="IV%"     MappingName="IV"           Width="90"  TextAlignment="Right" DisplayBinding="{Binding IV, StringFormat=F2}"/>
                            <syncfusion:GridTextColumn HeaderText="Delta"   MappingName="Delta"        Width="90"  TextAlignment="Right" DisplayBinding="{Binding Delta, StringFormat=F3}"/>
                            <syncfusion:GridTextColumn HeaderText="Gamma"   MappingName="Gamma"        Width="90"  TextAlignment="Right" DisplayBinding="{Binding Gamma, StringFormat=F4}"/>
                            <syncfusion:GridTextColumn HeaderText="Theta"   MappingName="Theta"        Width="90"  TextAlignment="Right" DisplayBinding="{Binding Theta, StringFormat=F2}"/>
                            <syncfusion:GridTextColumn HeaderText="Vega"    MappingName="Vega"         Width="90"  TextAlignment="Right" DisplayBinding="{Binding Vega, StringFormat=F2}"/>
                            <syncfusion:GridTextColumn HeaderText="DTE"     MappingName="DaysToExpiry" Width="70"  TextAlignment="Center"/>
                            <syncfusion:GridTextColumn HeaderText="Symbol"  MappingName="Symbol"       Width="180"/>
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                </Grid>
            </TabItem>

            <!-- ANALYTICS -->
            <TabItem Style="{StaticResource M3Tab}" Header="↗  Analytics">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,16">
                        <Border Style="{StaticResource KpiTile}" Background="{StaticResource PrimaryLight}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="PROFIT EFFICIENCY" Foreground="{StaticResource Primary}" FontSize="10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ProfitEfficiency, StringFormat={}{0:N0}}" Foreground="{StaticResource OnSurface}" FontSize="30"/>
                                    <TextBlock Text="%" Foreground="{StaticResource OnSurface}" FontSize="18" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                                <TextBlock Text="Actual vs protected" Foreground="{StaticResource Muted}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiTile}" Background="{StaticResource PositiveLight}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="RESCUED CAPITAL" Foreground="{StaticResource Positive}" FontSize="10"/>
                                <TextBlock Text="{Binding RescuedCapital, StringFormat=₹{0:N0}}" Foreground="{StaticResource OnSurface}" FontSize="28" Margin="0,6,0,0"/>
                                <TextBlock Text="Locked via TSL" Foreground="{StaticResource Muted}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiTile}" Background="{StaticResource NegativeLight}">
                            <StackPanel>
                                <TextBlock Text="AVG SLIPPAGE" Foreground="{StaticResource Negative}" FontSize="10"/>
                                <TextBlock Text="{Binding AvgSlippage, StringFormat=₹{0:N0}}" Foreground="{StaticResource OnSurface}" FontSize="28" Margin="0,6,0,0"/>
                                <TextBlock Text="Execution variance" Foreground="{StaticResource Muted}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
                        <syncfusion:SfDataGrid ItemsSource="{Binding ClosedTradeAnalytics}" AutoGenerateColumns="False"
                            AllowSorting="True" HeaderRowHeight="36" RowHeight="44"
                            GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0">
                            <syncfusion:SfDataGrid.Columns>
                                <syncfusion:GridTextColumn HeaderText="Strategy"  MappingName="StrategyName"    Width="180"/>
                                <syncfusion:GridTextColumn HeaderText="Symbol"    MappingName="Symbol"          Width="140"/>
                                <syncfusion:GridTextColumn HeaderText="Potential" MappingName="PotentialProfit" Width="110" TextAlignment="Right" DisplayBinding="{Binding PotentialProfit, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="Protected" MappingName="ProtectedProfit" Width="110" TextAlignment="Right" DisplayBinding="{Binding ProtectedProfit, StringFormat=N2}"/>
                                <syncfusion:GridTextColumn HeaderText="Actual"    MappingName="ActualProfit"    Width="110" TextAlignment="Right" DisplayBinding="{Binding ActualProfit, StringFormat=N2}"/>
                            </syncfusion:SfDataGrid.Columns>
                        </syncfusion:SfDataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ACCOUNTS -->
            <TabItem Style="{StaticResource M3Tab}" Header="⊙  Accounts">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SurfaceVariant}" Padding="16,10"
                            BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Add Account" Style="{StaticResource FilledBtn}"
                                    Command="{Binding AccountManager.OpenAddAccountCommand}"
                                    Visibility="{Binding AccountManager.IsAdminMode, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,10,0"/>
                            <Button Content="⟳ Refresh" Style="{StaticResource TonalBtn}"/>
                        </StackPanel>
                    </Border>
                    <syncfusion:SfDataGrid Grid.Row="1" ItemsSource="{Binding AccountManager.Accounts}" AutoGenerateColumns="False"
                        AllowSorting="True" HeaderRowHeight="38" RowHeight="44"
                        GridLinesVisibility="Horizontal" Background="{StaticResource PageBg}">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="A/C Name"    MappingName="AccountName"    Width="160"/>
                            <syncfusion:GridTextColumn HeaderText="Broker"       MappingName="Broker"         Width="110"/>
                            <syncfusion:GridTextColumn HeaderText="Client ID"    MappingName="ClientId"       Width="110"/>
                            <syncfusion:GridTextColumn HeaderText="Status"       MappingName="Status"         Width="110"/>
                            <syncfusion:GridTextColumn HeaderText="P&amp;L"     MappingName="Pnl"            Width="120" TextAlignment="Right" DisplayBinding="{Binding Pnl, StringFormat=₹{0:N0}}"/>
                            <syncfusion:GridTextColumn HeaderText="Funds Avail"  MappingName="FundsAvailable" Width="120" TextAlignment="Right"/>
                            <syncfusion:GridTextColumn HeaderText="Pos Open"     MappingName="PositionOpen"   Width="90"  TextAlignment="Right"/>
                            <syncfusion:GridTextColumn HeaderText="Ord Compl"    MappingName="OrderCompl"     Width="90"  TextAlignment="Right"/>
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ─── SPLITTER ──────────────────────────────────── -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="{StaticResource Outline}" Cursor="SizeNS"/>

        <!-- ─── LOG PANEL ─────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource SurfaceVariant}"
                        BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="System Log" Foreground="{StaticResource Muted}"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Content="Clear" Style="{StaticResource TonalBtn}"
                                Command="{Binding ClearLogCommand}" Margin="12,0,0,0" Padding="10,3" FontSize="11"/>
                    </StackPanel>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding Logs}"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="Cascadia Code, Consolas" FontSize="11"
                         VirtualizingPanel.IsVirtualizing="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         Padding="8,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{Binding Converter={StaticResource LogColorConverter}}" Margin="0,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
